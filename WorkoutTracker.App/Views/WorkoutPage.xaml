<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
       x:Name="Page"
       xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       x:Class="WorkoutTracker.Views.WorkoutPage"
       Title="Add Workout">

       <ContentPage.Resources>
              <DataTemplate x:Key="RecommendedWorkoutTemplate">
                     <Border Padding="10"
                             Margin="0,0,0,8"
                             Stroke="{AppThemeBinding Light=#C7D8BF, Dark={StaticResource Gray500}}"
                             BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}"
                             StrokeShape="RoundRectangle 8">
                            <Border.Triggers>
                                   <DataTrigger TargetType="Border"
                                                Binding="{Binding IsSelected}"
                                                Value="True">
                                          <Setter Property="Stroke"
                                                        Value="{AppThemeBinding Light=#0F766E, Dark=#14B8A6}"/>
                                          <Setter Property="BackgroundColor"
                                                        Value="{AppThemeBinding Light=#F0FDFA, Dark=#10211C}"/>
                                   </DataTrigger>
                            </Border.Triggers>
                            <VerticalStackLayout Spacing="4">
                                           <Grid ColumnDefinitions="*,Auto"
                                                 ColumnSpacing="8">
                                                  <Label Grid.Column="0"
                                                         Text="{Binding Workout.Name}"
                                                         FontAttributes="Bold"
                                                         Margin="0"
                                                         VerticalOptions="Center"
                                                         HorizontalOptions="Fill"
                                                         LineBreakMode="WordWrap"
                                                         MaxLines="2"/>
                                                   <Button Grid.Column="1"
                                                           Text="{Binding ActionButtonText}"
                                                           Command="{Binding Source={x:Reference Page}, Path=BindingContext.UseRecommendedWorkoutCommand}"
                                                    CommandParameter="{Binding .}"
                                                   Padding="8,0"
                                                   MinimumHeightRequest="26"
                                                   HeightRequest="26"
                                                   FontSize="12"
                                                   VerticalOptions="Start"
                                                   BackgroundColor="{AppThemeBinding Light=#0F766E, Dark=#14B8A6}"
                                                   TextColor="White"
                                                   CornerRadius="8"
                                                   IsVisible="{Binding ShowUseButton}"/>
                                   </Grid>
                                   <Grid ColumnDefinitions="Auto,Auto,Auto"
                                         ColumnSpacing="16"
                                         HorizontalOptions="Start"
                                         IsVisible="{Binding ShowStrengthDetails}">
                                           <VerticalStackLayout Grid.Column="0"
                                                                Spacing="1">
                                                  <Label Text="{Binding Workout.Sets, StringFormat='Sets: {0}'}"
                                                         FontSize="12"
                                                         TextColor="{AppThemeBinding Light=#6A7686, Dark=#9BABBE}"
                                                         LineBreakMode="TailTruncation"/>
                                                  <Label Text="{Binding RepDisplayText}"
                                                         FontSize="12"
                                                         TextColor="{AppThemeBinding Light=#6A7686, Dark=#9BABBE}"
                                                         LineBreakMode="TailTruncation"
                                                         IsVisible="{Binding HasRepDisplay}"/>
                                                  <Label Text="{Binding DurationDisplayText}"
                                                         FontSize="12"
                                                         TextColor="{AppThemeBinding Light=#6A7686, Dark=#9BABBE}"
                                                         LineBreakMode="TailTruncation"
                                                         IsVisible="{Binding HasDuration}"/>
                                           </VerticalStackLayout>
                                           <VerticalStackLayout Grid.Column="1"
                                                                Spacing="1">
                                                  <Label Text="{Binding WeightDisplayText}"
                                                         FontSize="12"
                                                         TextColor="{AppThemeBinding Light=#6A7686, Dark=#9BABBE}"
                                                         LineBreakMode="TailTruncation"
                                                         IsVisible="{Binding HasWeightDisplay}"/>
                                                 <Label Text="{Binding Workout.MuscleGroup, StringFormat='Focus: {0}'}"
                                                        FontSize="12"
                                                        TextColor="{AppThemeBinding Light=#6A7686, Dark=#9BABBE}"
                                                        LineBreakMode="TailTruncation"/>
                                          </VerticalStackLayout>
                                          <VerticalStackLayout Grid.Column="2"
                                                               Spacing="1">
                                                 <Label Text="{Binding TargetRpeText}"
                                                        FontSize="12"
                                                        TextColor="{AppThemeBinding Light=#6A7686, Dark=#9BABBE}"
                                                        LineBreakMode="TailTruncation"
                                                        IsVisible="{Binding HasTargetRpe}"/>
                                                 <Label Text="{Binding TargetRestText}"
                                                        FontSize="12"
                                                        TextColor="{AppThemeBinding Light=#6A7686, Dark=#9BABBE}"
                                                        LineBreakMode="TailTruncation"
                                                        IsVisible="{Binding HasTargetRest}"/>
                                          </VerticalStackLayout>
                                   </Grid>
                                   <Grid ColumnDefinitions="Auto,Auto,Auto"
                                         ColumnSpacing="16"
                                         HorizontalOptions="Start"
                                         IsVisible="{Binding ShowCardioDetails}">
                                          <VerticalStackLayout Grid.Column="0"
                                                               Spacing="1">
                                                 <Label Text="{Binding DurationDisplayText}"
                                                        FontSize="12"
                                                        TextColor="{AppThemeBinding Light=#6A7686, Dark=#9BABBE}"
                                                        LineBreakMode="TailTruncation"
                                                        IsVisible="{Binding HasDuration}"/>
                                                 <Label Text="{Binding DistanceDisplayText}"
                                                        FontSize="12"
                                                        TextColor="{AppThemeBinding Light=#6A7686, Dark=#9BABBE}"
                                                        LineBreakMode="TailTruncation"
                                                        IsVisible="{Binding HasDistance}"/>
                                          </VerticalStackLayout>
                                          <VerticalStackLayout Grid.Column="1"
                                                               Spacing="1">
                                                 <Label Text="{Binding TargetRpeText}"
                                                        FontSize="12"
                                                        TextColor="{AppThemeBinding Light=#6A7686, Dark=#9BABBE}"
                                                        LineBreakMode="TailTruncation"
                                                        IsVisible="{Binding HasTargetRpe}"/>
                                                 <Label Text="{Binding Workout.MuscleGroup, StringFormat='Focus: {0}'}"
                                                        FontSize="12"
                                                        TextColor="{AppThemeBinding Light=#6A7686, Dark=#9BABBE}"
                                                        LineBreakMode="TailTruncation"/>
                                          </VerticalStackLayout>
                                   </Grid>
                                     <Label Text="{Binding SelectedText}"
                                            FontSize="12"
                                            FontAttributes="Bold"
                                            TextColor="{AppThemeBinding Light=#0F766E, Dark=#7DE6D7}"
                                            IsVisible="{Binding ShowSelectedState}"/>
                             </VerticalStackLayout>
                      </Border>
               </DataTemplate>
       </ContentPage.Resources>

       <Grid>
              <Grid x:Name="WorkoutContentHost">
              <ScrollView x:Name="PageScrollView">
                     <VerticalStackLayout Padding="20"
                                   Spacing="5">
                     <Label Text="Add a Workout"
                            FontSize="20"
                            HorizontalOptions="Center"/>
                     <Label Text="{Binding TodayLabel, StringFormat='Today: {0}'}"
                            FontSize="14"
                            HorizontalOptions="Center"
                            TextColor="Gray"/>

                     <Button Text="{Binding ManualWorkoutButtonText}"
                             Command="{Binding ShowManualWorkoutEntryCommand}"
                             HorizontalOptions="Fill"
                             BackgroundColor="{AppThemeBinding Light=#E7F6F4, Dark=#143936}"
                             TextColor="{AppThemeBinding Light=#0F766E, Dark=#7DE6D7}"
                             Margin="0,8,0,8"
                             IsVisible="{Binding ShowTopManualWorkoutButton}"/>

                     <Button Text="Track Cardio Session"
                             Command="{Binding StartManualCardioSessionCommand}"
                             HorizontalOptions="Fill"
                             BackgroundColor="{AppThemeBinding Light=#E7F6F4, Dark=#143936}"
                             TextColor="{AppThemeBinding Light=#0F766E, Dark=#7DE6D7}"
                             Margin="0,8,0,8"
                             IsVisible="{Binding ShowTrackCardioSessionButton}"/>

                     <Button Text="← Back to Active Plan"
                             Command="{Binding BackToPlanSuggestionsCommand}"
                             HorizontalOptions="Start"
                             BackgroundColor="Transparent"
                             TextColor="{AppThemeBinding Light=#0F766E, Dark=#7DE6D7}"
                             Padding="0"
                             Margin="0,0,0,8"
                             IsVisible="{Binding ShowBackToPlanButton}"/>

                     <Border Stroke="{AppThemeBinding Light=#D9E5D2, Dark={StaticResource Gray500}}"
                             StrokeThickness="1"
                             StrokeShape="RoundRectangle 12"
                             BackgroundColor="{AppThemeBinding Light=#F7FBF4, Dark={StaticResource Gray950}}"
                             Padding="14"
                             Margin="0,8,0,12"
                             IsVisible="{Binding ShowPlanSection}">
                            <VerticalStackLayout Spacing="10">
                                   <HorizontalStackLayout Spacing="8"
                                                          IsVisible="{Binding ShowPlanSuggestionsSection}">
                                          <Label Text="Active Plan Suggestions"
                                                 FontAttributes="Bold"
                                                 FontSize="18"
                                                 VerticalOptions="Center"/>
                                   </HorizontalStackLayout>

                                   <Border Stroke="{AppThemeBinding Light=#D8E0EB, Dark=#2B3544}"
                                           StrokeThickness="1"
                                           StrokeShape="RoundRectangle 12"
                                           BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#101720}"
                                           Padding="12,10"
                                           IsVisible="{Binding ShowRpeHelp}">
                                          <Label Text="{Binding RpeHelpText}"
                                                 FontSize="12"
                                                 TextColor="{AppThemeBinding Light=#667384, Dark=#A2B0C2}"/>
                                   </Border>

                                   <Label Text="{Binding ActivePlanSummary}"
                                          FontSize="13"
                                          TextColor="{AppThemeBinding Light=#5E6B7B, Dark=#A4B2C5}"
                                          IsVisible="{Binding ShowPlanCompletedSummary}"/>

                                   <Button Text="{Binding ManualWorkoutButtonText}"
                                           Command="{Binding ShowManualWorkoutEntryCommand}"
                                           HorizontalOptions="Center"
                                           IsVisible="{Binding ShowManualWorkoutPrompt}"/>

                                   <VerticalStackLayout BindableLayout.ItemsSource="{Binding RecommendedPlanWorkouts}"
                                                        BindableLayout.ItemTemplate="{StaticResource RecommendedWorkoutTemplate}"
                                                        IsVisible="{Binding ShowCompactPlanSuggestions}"
                                                        Spacing="0"/>

                                   <CollectionView ItemsSource="{Binding RecommendedPlanWorkouts}"
                                                   x:Name="RecommendationsList"
                                                   IsVisible="{Binding ShowScrollablePlanSuggestions}"
                                                   SelectionMode="None"
                                                   ItemSizingStrategy="MeasureAllItems"
                                                   HeightRequest="220">
                                          <CollectionView.ItemTemplate>
                                                 <StaticResource Key="RecommendedWorkoutTemplate"/>
                                          </CollectionView.ItemTemplate>
                                   </CollectionView>
                            </VerticalStackLayout>
                     </Border>

                     <Border IsVisible="{Binding ShowQuickAddCard}"
                             Stroke="#D5DAE1"
                             StrokeThickness="1"
                             StrokeShape="RoundRectangle 10"
                             Padding="12"
                             Margin="0,0,0,10">
                            <Grid RowDefinitions="Auto,Auto"
                                          RowSpacing="4">
                                    <Grid Grid.Row="0">
                                           <HorizontalStackLayout Spacing="8"
                                                                  VerticalOptions="Center">
                                                  <Label Text="{Binding QuickEditExerciseName}"
                                                         FontAttributes="Bold"
                                                         FontSize="16"
                                                         VerticalOptions="Center"
                                                         IsVisible="{Binding ShowQuickAddReadOnlySummary}"/>
                                                  <Entry Text="{Binding Name}"
                                                         FontAttributes="Bold"
                                                         FontSize="16"
                                                         VerticalOptions="Center"
                                                         HorizontalOptions="FillAndExpand"
                                                         IsVisible="{Binding ShowQuickAddInlineEditors}"/>
                                                  <ImageButton Source="info.png"
                                                               HeightRequest="18"
                                                               WidthRequest="18"
                                                               MinimumHeightRequest="18"
                                                               MinimumWidthRequest="18"
                                                               Padding="0"
                                                               BackgroundColor="Transparent"
                                                               VerticalOptions="Center"
                                                               IsVisible="{Binding ShowQuickEditExerciseInfo}"
                                                               Clicked="OnSelectedExerciseImageClicked"/>
                                           </HorizontalStackLayout>
                                    </Grid>
                                   <Grid Grid.Row="1"
                                         ColumnDefinitions="Auto,Auto,Auto"
                                         ColumnSpacing="12"
                                         HorizontalOptions="Start"
                                         IsVisible="{Binding ShowQuickAddReadOnlySummary}">
                                           <VerticalStackLayout Grid.Column="0"
                                                                Spacing="1">
                                                  <Label Text="{Binding CurrentSetSummary}"
                                                         FontSize="12"
                                                         TextColor="{AppThemeBinding Light=#6A7686, Dark=#9BABBE}"/>
                                                 <Label Text="{Binding CurrentRepsSummary}"
                                                        FontSize="12"
                                                        TextColor="{AppThemeBinding Light=#6A7686, Dark=#9BABBE}"/>
                                          </VerticalStackLayout>
                                          <VerticalStackLayout Grid.Column="1"
                                                               Spacing="1">
                                                  <Label Text="{Binding QuickAddWeightSummaryText}"
                                                         FontSize="12"
                                                         TextColor="{AppThemeBinding Light=#6A7686, Dark=#9BABBE}"
                                                         IsVisible="{Binding HasQuickAddWeightSummary}"/>
                                                 <Label Text="{Binding WeightTotalPreviewText}"
                                                        FontSize="11"
                                                        TextColor="{AppThemeBinding Light=#6A7686, Dark=#9BABBE}"
                                                        IsVisible="{Binding ShowWeightTotalPreview}"/>
                                                 <Label Text="{Binding SelectedMuscleGroup, StringFormat='Focus: {0}'}"
                                                        FontSize="12"
                                                        TextColor="{AppThemeBinding Light=#6A7686, Dark=#9BABBE}"/>
                                          </VerticalStackLayout>
                                          <VerticalStackLayout Grid.Column="2"
                                                               Spacing="1">
                                                 <Label Text="{Binding PlannedTargetRpeSummary}"
                                                        FontSize="11"
                                                        TextColor="{AppThemeBinding Light=#6A7686, Dark=#9BABBE}"
                                                        IsVisible="{Binding HasPlannedTargetRpe}"/>
                                                 <Label Text="{Binding PlannedTargetRestSummary}"
                                                        FontSize="11"
                                                        TextColor="{AppThemeBinding Light=#6A7686, Dark=#9BABBE}"
                                                        IsVisible="{Binding HasPlannedTargetRest}"/>
                                          </VerticalStackLayout>
                                   </Grid>
                                   <Grid Grid.Row="1"
                                          ColumnDefinitions="*,*,*"
                                          ColumnSpacing="8"
                                          RowDefinitions="Auto,Auto,Auto"
                                          RowSpacing="4"
                                          HorizontalOptions="Fill"
                                          IsVisible="{Binding ShowQuickAddInlineEditors}">
                                            <Grid Grid.Column="0"
                                                  RowDefinitions="Auto,Auto"
                                                  RowSpacing="4"
                                                  HorizontalOptions="Fill">
                                                   <VerticalStackLayout Grid.Row="0"
                                                                        Spacing="2">
                                                         <Grid ColumnDefinitions="20,*,20"
                                                               ColumnSpacing="4"
                                                               HorizontalOptions="Fill">
                                                                <Label Grid.Column="1"
                                                                       Text="Sets"
                                                                       FontSize="12"
                                                                       TextColor="{AppThemeBinding Light=#6A7686, Dark=#9BABBE}"
                                                                       HorizontalTextAlignment="Center"/>
                                                         </Grid>
                                                         <Grid ColumnDefinitions="20,*,20"
                                                               ColumnSpacing="4"
                                                               HorizontalOptions="Fill">
                                                                 <Button Text="-"
                                                                         Padding="0"
                                                                         HeightRequest="20"
                                                                         WidthRequest="20"
                                                                         MinimumHeightRequest="20"
                                                                         MinimumWidthRequest="20"
                                                                         FontSize="11"
                                                                         IsEnabled="{Binding CanDecreaseSets}"
                                                                         Command="{Binding DecreaseSetsCommand}"/>
                                                                   <Entry Grid.Column="1"
                                                                          Text="{Binding PlannedSetsInput}"
                                                                          Placeholder="0"
                                                                         Keyboard="Numeric"
                                                                         FontSize="12"
                                                                         HorizontalTextAlignment="Center"
                                                                        TextChanged="SetsEntry_TextChanged"
                                                                        MinimumWidthRequest="24"/>
                                                                 <Button Grid.Column="2"
                                                                         Text="+"
                                                                         Padding="0"
                                                                         HeightRequest="20"
                                                                         WidthRequest="20"
                                                                         MinimumHeightRequest="20"
                                                                         MinimumWidthRequest="20"
                                                                         FontSize="11"
                                                                         IsEnabled="{Binding CanIncreaseSets}"
                                                                         Command="{Binding IncreaseSetsCommand}"/>
                                                         </Grid>
                                                   </VerticalStackLayout>
                                                    <VerticalStackLayout Grid.Row="1"
                                                                         Spacing="2">
                                                         <Grid ColumnDefinitions="20,*,20"
                                                               ColumnSpacing="4"
                                                               HorizontalOptions="Fill">
                                                                <Label Grid.Column="1"
                                                                       Text="{Binding RepsLabel}"
                                                                       FontSize="12"
                                                                      TextColor="{AppThemeBinding Light=#6A7686, Dark=#9BABBE}"
                                                                      HorizontalTextAlignment="Center"/>
                                                        </Grid>
                                                         <Grid ColumnDefinitions="20,*,20"
                                                               ColumnSpacing="4"
                                                               HorizontalOptions="Fill">
                                                                <Button Text="-"
                                                                        Padding="0"
                                                                        HeightRequest="20"
                                                                        WidthRequest="20"
                                                                        MinimumHeightRequest="20"
                                                                        MinimumWidthRequest="20"
                                                                        FontSize="11"
                                                                        Command="{Binding DecreaseRepsCommand}"/>
                                                                 <Entry Grid.Column="1"
                                                                        Text="{Binding StrengthTargetValue}"
                                                                        Placeholder="0"
                                                                         Keyboard="Numeric"
                                                                         FontSize="12"
                                                                        HorizontalTextAlignment="Center"
                                                                        TextChanged="RepsEntry_TextChanged"
                                                                        MinimumWidthRequest="24"/>
                                                                <Button Grid.Column="2"
                                                                        Text="+"
                                                                        Padding="0"
                                                                        HeightRequest="20"
                                                                        WidthRequest="20"
                                                                        MinimumHeightRequest="20"
                                                                        MinimumWidthRequest="20"
                                                                        FontSize="11"
                                                                        Command="{Binding IncreaseRepsCommand}"/>
                                                         </Grid>
                                                   </VerticalStackLayout>
                                             </Grid>
                                            <Grid Grid.Column="1"
                                                  RowDefinitions="Auto,Auto,Auto"
                                                  RowSpacing="4"
                                                  HorizontalOptions="Fill">
                                                   <VerticalStackLayout Grid.Row="0"
                                                                        Spacing="2">
                                                         <Grid ColumnDefinitions="20,*,20"
                                                               ColumnSpacing="2"
                                                               HorizontalOptions="Fill"
                                                               IsVisible="{Binding ShowStandaloneWeightValueInput}">
                                                                <Label Grid.Column="1"
                                                                       Text="{Binding WeightLabel}"
                                                                       FontSize="12"
                                                                      TextColor="{AppThemeBinding Light=#6A7686, Dark=#9BABBE}"
                                                                      HorizontalTextAlignment="Center"/>
                                                        </Grid>
                                                         <Grid ColumnDefinitions="20,*,20"
                                                               ColumnSpacing="2"
                                                               HorizontalOptions="Fill"
                                                               IsVisible="{Binding ShowStandardWeightInput}">
                                                                <Button Text="-"
                                                                        WidthRequest="20"
                                                                        HeightRequest="20"
                                                                        MinimumHeightRequest="20"
                                                                        MinimumWidthRequest="20"
                                                                        Padding="0"
                                                                        FontSize="11"
                                                                        CommandParameter="-5"
                                                                       Clicked="StandardWeightAdjust_Clicked"
                                                                       Pressed="StandardWeightAdjust_Pressed"
                                                                       Released="StandardWeightAdjust_Released"/>
                                                                 <Entry Grid.Column="1"
                                                                 Text="{Binding Weight}"
                                                                 Placeholder="{Binding QuickEditWeightPlaceholder}"
                                                                 Keyboard="Numeric"
                                                                 FontSize="12"
                                                                 HorizontalTextAlignment="Center"
                                                                 MinimumWidthRequest="28"
                                                                 Focused="WeightEntry_Focused"
                                                                 Completed="Entry_Completed"
                                                                 TextChanged="WeightEntry_TextChanged"
                                                                 Unfocused="WeightEntry_Unfocused"/>
                                                                <Button Grid.Column="2"
                                                                        Text="+"
                                                                        WidthRequest="20"
                                                                        HeightRequest="20"
                                                                        MinimumHeightRequest="20"
                                                                        MinimumWidthRequest="20"
                                                                        Padding="0"
                                                                        FontSize="11"
                                                                        CommandParameter="5"
                                                                       Clicked="StandardWeightAdjust_Clicked"
                                                                       Pressed="StandardWeightAdjust_Pressed"
                                                                       Released="StandardWeightAdjust_Released"/>
                                                        </Grid>
                                                         <Grid ColumnDefinitions="20,*,20"
                                                               ColumnSpacing="2"
                                                               HorizontalOptions="Fill"
                                                               IsVisible="{Binding ShowResistanceAdjustment}">
                                                                 <Button Text="-"
                                                                         WidthRequest="20"
                                                                         HeightRequest="20"
                                                                         MinimumHeightRequest="20"
                                                                         MinimumWidthRequest="20"
                                                                         Padding="0"
                                                                         FontSize="11"
                                                                         IsEnabled="{Binding CanDecreaseWeight}"
                                                                         CommandParameter="-5"
                                                                        Clicked="BodyweightWeightAdjust_Clicked"
                                                                        Pressed="BodyweightWeightAdjust_Pressed"
                                                                        Released="BodyweightWeightAdjust_Released"/>
                                                                 <Entry Grid.Column="1"
                                                                        Text="{Binding Weight}"
                                                                        Placeholder="{Binding WeightPlaceholder}"
                                                                        Keyboard="Numeric"
                                                                        FontSize="12"
                                                                        HorizontalTextAlignment="Center"
                                                                        MinimumWidthRequest="28"
                                                                        TextChanged="WeightEntry_TextChanged"/>
                                                                <Button Grid.Column="2"
                                                                        Text="+"
                                                                        WidthRequest="20"
                                                                        HeightRequest="20"
                                                                        MinimumHeightRequest="20"
                                                                        MinimumWidthRequest="20"
                                                                        Padding="0"
                                                                        FontSize="11"
                                                                        CommandParameter="5"
                                                                       Clicked="BodyweightWeightAdjust_Clicked"
                                                                       Pressed="BodyweightWeightAdjust_Pressed"
                                                                       Released="BodyweightWeightAdjust_Released"/>
                                                        </Grid>
                                                         <Grid Grid.ColumnSpan="2"
                                                               ColumnDefinitions="24,60,24"
                                                               ColumnSpacing="2"
                                                               Margin="4,0,0,0"
                                                               HorizontalOptions="Start"
                                                              IsVisible="False">
                                                               <Button Text="-"
                                                                       WidthRequest="24"
                                                                       HeightRequest="24"
                                                                       MinimumHeightRequest="24"
                                                                       MinimumWidthRequest="24"
                                                                       Padding="0"
                                                                       FontSize="11"
                                                                       CommandParameter="-5"
                                                                       Clicked="ResistanceAdjust_Clicked"
                                                                       Pressed="ResistanceAdjust_Pressed"
                                                                       Released="ResistanceAdjust_Released"/>
                                                               <Border Grid.Column="1"
                                                                       Stroke="{AppThemeBinding Light=#D8E0EB, Dark=#2B3544}"
                                                                       StrokeShape="RoundRectangle 10"
                                                                       Padding="0"
                                                                       VerticalOptions="Center">
                                                                      <Entry Text="{Binding ResistanceAdjustment}"
                                                                             Keyboard="Numeric"
                                                                             BackgroundColor="Transparent"
                                                                             ClearButtonVisibility="Never"
                                                                             FontSize="12"
                                                                             HorizontalTextAlignment="Center"
                                                                             VerticalTextAlignment="Center"
                                                                             Margin="0"
                                                                             MaxLength="6"/>
                                                               </Border>
                                                               <Button Grid.Column="2"
                                                                       Text="+"
                                                                       WidthRequest="24"
                                                                       HeightRequest="24"
                                                                       MinimumHeightRequest="24"
                                                                       MinimumWidthRequest="24"
                                                                       Padding="0"
                                                                       FontSize="11"
                                                                        CommandParameter="5"
                                                                        Clicked="ResistanceAdjust_Clicked"
                                                                        Pressed="ResistanceAdjust_Pressed"
                                                                        Released="ResistanceAdjust_Released"/>
                                                         </Grid>
                                                  </VerticalStackLayout>
                                                  <Grid Grid.Row="1"
                                                        ColumnDefinitions="Auto,*"
                                                        ColumnSpacing="4">
                                                        <Label Text="{Binding WeightTotalPreviewText}"
                                                               FontSize="11"
                                                               TextColor="{AppThemeBinding Light=#6A7686, Dark=#9BABBE}"
                                                               Grid.ColumnSpan="2"
                                                               IsVisible="{Binding ShowWeightTotalPreview}"/>
                                                 </Grid>
                                                   <VerticalStackLayout Grid.Row="2"
                                                                        Spacing="2">
                                                         <Label Text="Focus"
                                                                FontSize="12"
                                                                TextColor="{AppThemeBinding Light=#6A7686, Dark=#9BABBE}"
                                                                HorizontalTextAlignment="Center"/>
                                                          <Picker Title="Select Muscle Group"
                                                                  FontSize="12"
                                                                  HorizontalOptions="Fill"
                                                                  HorizontalTextAlignment="Center"
                                                                  IsEnabled="{Binding CanEditSelectedMuscleGroup}"
                                                                  ItemsSource="{Binding MuscleGroups}"
                                                                  SelectedItem="{Binding SelectedMuscleGroup}"/>
                                                  </VerticalStackLayout>
                                            </Grid>

                                             <Grid Grid.Column="2"
                                                   RowDefinitions="Auto,Auto,Auto"
                                                   RowSpacing="4"
                                                   HorizontalOptions="Fill"
                                                   IsVisible="{Binding ShowQuickEditTargetsColumn}">
                                                    <VerticalStackLayout Grid.Row="0"
                                                                         Spacing="2"
                                                                         HorizontalOptions="Fill"
                                                                         VerticalOptions="Start"
                                                                         IsVisible="{Binding ShowQuickEditTargetRpe}">
                                                         <Grid ColumnDefinitions="20,*,20"
                                                               ColumnSpacing="0"
                                                               HorizontalOptions="Fill">
                                                                <Label Grid.Column="1"
                                                                       Text="RPE"
                                                                       FontSize="12"
                                                                       TextColor="{AppThemeBinding Light=#6A7686, Dark=#9BABBE}"
                                                                       HorizontalTextAlignment="Center"/>
                                                         </Grid>
                                                         <Grid ColumnDefinitions="20,*,20"
                                                               ColumnSpacing="0"
                                                               HorizontalOptions="Fill">
                                                                <Entry Grid.Column="1"
                                                                       Text="{Binding PlannedTargetRpeInput}"
                                                                       Placeholder="RPE"
                                                                       Keyboard="Numeric"
                                                                       FontSize="12"
                                                                       HorizontalTextAlignment="Center"
                                                                       IsVisible="{Binding CanEditPlannedTargets}"/>
                                                                 <Grid Grid.Column="1"
                                                                      HeightRequest="32"
                                                                      VerticalOptions="End"
                                                                      Margin="0,4,0,0"
                                                                      IsVisible="{Binding ShowReadOnlyPlannedTargets}">
                                                                        <VerticalStackLayout Spacing="3"
                                                                                            VerticalOptions="End">
                                                                        <Label Text="{Binding PlannedTargetRpeValue}"
                                                                               FontSize="12"
                                                                               TextColor="#334155"
                                                                               HorizontalTextAlignment="Center"/>
                                                                        <BoxView HeightRequest="1"
                                                                                 Margin="6,0"
                                                                                 HorizontalOptions="Fill"
                                                                                 Color="#334155"/>
                                                                       </VerticalStackLayout>
                                                                </Grid>
                                                         </Grid>
                                                   </VerticalStackLayout>

                                                     <VerticalStackLayout Grid.Row="2"
                                                                          Spacing="2"
                                                                          HorizontalOptions="Fill"
                                                                          VerticalOptions="Start"
                                                                         IsVisible="{Binding ShowQuickEditTargetRest}">
                                                         <Grid ColumnDefinitions="20,*,20"
                                                               ColumnSpacing="0"
                                                               HorizontalOptions="Fill">
                                                                <Label Grid.Column="1"
                                                                       Text="Rest"
                                                                       FontSize="12"
                                                                       TextColor="{AppThemeBinding Light=#6A7686, Dark=#9BABBE}"
                                                                       Margin="0,4,0,0"
                                                                       HorizontalTextAlignment="Center"/>
                                                         </Grid>
                                                         <Grid ColumnDefinitions="20,*,20"
                                                               ColumnSpacing="0"
                                                               HorizontalOptions="Fill">
                                                                <Entry Grid.Column="1"
                                                                       Text="{Binding PlannedTargetRestInput}"
                                                                       Placeholder="Rest"
                                                                       FontSize="12"
                                                                       HorizontalTextAlignment="Center"
                                                                       IsVisible="{Binding CanEditPlannedTargets}"/>
                                                                 <Grid Grid.Column="1"
                                                                      HeightRequest="32"
                                                                      VerticalOptions="End"
                                                                      Margin="0,8,0,0"
                                                                      IsVisible="{Binding ShowReadOnlyPlannedTargets}">
                                                                        <VerticalStackLayout Spacing="3"
                                                                                            VerticalOptions="End">
                                                                        <Label Text="{Binding PlannedTargetRestValue}"
                                                                               FontSize="12"
                                                                               TextColor="#334155"
                                                                               HorizontalTextAlignment="Center"
                                                                               LineBreakMode="TailTruncation"/>
                                                                        <BoxView HeightRequest="1"
                                                                                 Margin="6,0"
                                                                                 HorizontalOptions="Fill"
                                                                                 Color="#334155"/>
