                                                                 Command="{Binding IncreaseSetsCommand}"/>
                                                 </Grid>
                                                 <Label Text="{Binding QuickSetProgressText}"
                                                        FontSize="11"
                                                        HorizontalTextAlignment="Center"
                                                        TextColor="{AppThemeBinding Light=#6A7686, Dark=#9BABBE}"
                                                        IsVisible="{Binding ShowQuickSetProgress}">
                                                        <Label.Triggers>
                                                               <DataTrigger TargetType="Label"
                                                                            Binding="{Binding IsCompletingSelectedPlanExercise}"
                                                                            Value="True">
                                                                      <Setter Property="TextColor"
                                                                              Value="{AppThemeBinding Light=#DC2626, Dark=#F87171}"/>
                                                               </DataTrigger>
                                                        </Label.Triggers>
                                                 </Label>
                                           </VerticalStackLayout>
                                   </Grid>
                                   <Grid ColumnDefinitions="Auto,Auto"
                                         ColumnSpacing="18"
                                         HorizontalOptions="Center"
                                         IsVisible="{Binding ShowNoWeightStrengthInput}">
                                           <VerticalStackLayout Grid.Column="0"
                                                                Spacing="2"
                                                                HorizontalOptions="Center">
                                                 <Grid ColumnDefinitions="22,*,22"
                                                       ColumnSpacing="4"
                                                       HorizontalOptions="Fill">
                                                          <Label Grid.Column="1"
                                                                 Text="{Binding RepsLabel}"
                                                                 FontAttributes="Bold"
                                                                 FontSize="11"
                                                                 LineBreakMode="NoWrap"
                                                                 MaxLines="1"
                                                                 HorizontalOptions="Center"
                                                                 HorizontalTextAlignment="Center"/>
                                                  </Grid>
                                                 <Grid ColumnDefinitions="22,*,22"
                                                       ColumnSpacing="4"
                                                       HorizontalOptions="Fill">
                                                          <Button Text="-"
                                                                  Padding="0"
                                                                  HeightRequest="24"
                                                                  WidthRequest="22"
                                                                  MinimumHeightRequest="24"
                                                                  MinimumWidthRequest="22"
                                                                  FontSize="11"
                                                                  IsEnabled="{Binding CanDecreaseReps}"
                                                                  Command="{Binding DecreaseRepsCommand}"/>
                                                         <Entry Grid.Column="1"
                                                                Placeholder="1"
                                                                Keyboard="Numeric"
                                                                HorizontalTextAlignment="Center"
                                                                TextChanged="RepsEntry_TextChanged"
                                                                Text="{Binding StrengthTargetValue}"/>
                                                         <Button Grid.Column="2"
                                                                 Text="+"
                                                                 Padding="0"
                                                                 HeightRequest="24"
                                                                 WidthRequest="22"
                                                                 MinimumHeightRequest="24"
                                                                 MinimumWidthRequest="22"
                                                                 FontSize="11"
                                                                 Command="{Binding IncreaseRepsCommand}"/>
                                                 </Grid>
                                          </VerticalStackLayout>

                                          <VerticalStackLayout Grid.Column="1"
                                                               Spacing="2"
                                                               HorizontalOptions="Center">
                                                 <Grid ColumnDefinitions="22,56,22"
                                                       ColumnSpacing="4"
                                                       HorizontalOptions="Center">
                                                        <Label Grid.Column="1"
                                                               Text="Sets"
                                                               FontAttributes="Bold"
                                                               HorizontalTextAlignment="Center"/>
                                                 </Grid>
                                                 <Grid ColumnDefinitions="22,56,22"
                                                       ColumnSpacing="4"
                                                       HorizontalOptions="Center">
                                                        <Button Text="-"
                                                                Padding="0"
                                                                HeightRequest="24"
                                                                WidthRequest="22"
                                                                MinimumHeightRequest="24"
                                                                MinimumWidthRequest="22"
                                                                FontSize="11"
                                                                IsEnabled="{Binding CanDecreaseSets}"
                                                                Command="{Binding DecreaseSetsCommand}"/>
                                                        <Entry Grid.Column="1"
                                                               Placeholder="1"
                                                               Keyboard="Numeric"
                                                               HorizontalTextAlignment="Center"
                                                               TextChanged="SetsEntry_TextChanged"
                                                               Text="{Binding PlannedSetsInput}"/>
                                                        <Button Grid.Column="2"
                                                                Text="+"
                                                                Padding="0"
                                                                HeightRequest="24"
                                                                WidthRequest="22"
                                                                MinimumHeightRequest="24"
                                                                MinimumWidthRequest="22"
                                                                FontSize="11"
                                                                IsEnabled="{Binding CanIncreaseSets}"
                                                                Command="{Binding IncreaseSetsCommand}"/>
                                                 </Grid>
                                                 <Label Text="{Binding QuickSetProgressText}"
                                                        FontSize="11"
                                                        HorizontalTextAlignment="Center"
                                                        TextColor="{AppThemeBinding Light=#6A7686, Dark=#9BABBE}"
                                                        IsVisible="{Binding ShowQuickSetProgress}">
                                                        <Label.Triggers>
                                                               <DataTrigger TargetType="Label"
                                                                            Binding="{Binding IsCompletingSelectedPlanExercise}"
                                                                            Value="True">
                                                                      <Setter Property="TextColor"
                                                                              Value="{AppThemeBinding Light=#DC2626, Dark=#F87171}"/>
                                                               </DataTrigger>
                                                        </Label.Triggers>
                                                 </Label>
                                           </VerticalStackLayout>
                                    </Grid>

                                    <Border Stroke="{AppThemeBinding Light=#D8E0EB, Dark=#2B3544}"
                                            StrokeShape="RoundRectangle 12"
                                            Padding="12"
                                            BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#16202B}"
                                            IsVisible="{Binding ShowTimedManualCountdown}">
                                           <VerticalStackLayout Spacing="6"
                                                                HorizontalOptions="Center">
                                                  <Label Text="Countdown"
                                                         FontAttributes="Bold"
                                                         FontSize="12"
                                                         HorizontalTextAlignment="Center" />
                                                  <Label Text="{Binding TimedStrengthCountdownDisplay}"
                                                         FontAttributes="Bold"
                                                         FontSize="22"
                                                         HorizontalTextAlignment="Center"
                                                         HorizontalOptions="Center" />
                                                  <Button Text="{Binding TimedStrengthStartButtonText}"
                                                          Command="{Binding StartTimedStrengthCountdownCommand}"
                                                          IsEnabled="{Binding CanStartTimedStrengthCountdown}"
                                                          HeightRequest="32"
                                                          Padding="12,4" />
                                           </VerticalStackLayout>
                                    </Border>

                                     <Grid ColumnDefinitions="Auto,Auto,Auto"
                                           ColumnSpacing="18"
                                           HorizontalOptions="Center"
                                          IsVisible="{Binding ShowManualResistanceAdjustmentLayout}">
                                           <VerticalStackLayout Grid.Column="0"
                                                                Spacing="2"
                                                                HorizontalOptions="Center">
                                                 <Grid ColumnDefinitions="22,46,22"
                                                       ColumnSpacing="4"
                                                       HorizontalOptions="Center">
                                                        <Label Grid.Column="1"
                                                               Text="{Binding RepsLabel}"
                                                               FontAttributes="Bold"
                                                               HorizontalTextAlignment="Center"/>
                                                 </Grid>
                                                 <Grid ColumnDefinitions="22,46,22"
                                                       ColumnSpacing="4"
                                                       HorizontalOptions="Center">
                                                         <Button Text="-"
                                                                 Padding="0"
                                                                 HeightRequest="24"
                                                                 WidthRequest="22"
                                                                 MinimumHeightRequest="24"
                                                                 MinimumWidthRequest="22"
                                                                 FontSize="11"
                                                                 IsEnabled="{Binding CanDecreaseReps}"
                                                                 Command="{Binding DecreaseRepsCommand}"/>
                                                        <Entry Grid.Column="1"
                                                               Placeholder="1"
                                                               Keyboard="Numeric"
                                                               HorizontalTextAlignment="Center"
                                                               TextChanged="RepsEntry_TextChanged"
                                                               Text="{Binding StrengthTargetValue}"/>
                                                        <Button Grid.Column="2"
                                                                Text="+"
                                                                Padding="0"
                                                                HeightRequest="24"
                                                                WidthRequest="22"
                                                                MinimumHeightRequest="24"
                                                                MinimumWidthRequest="22"
                                                                FontSize="11"
                                                                Command="{Binding IncreaseRepsCommand}"/>
                                                 </Grid>
                                          </VerticalStackLayout>

                                          <VerticalStackLayout Grid.Column="1"
                                                               Spacing="2"
                                                               HorizontalOptions="Center">
                                                 <Grid ColumnDefinitions="24,60,24"
                                                       ColumnSpacing="2"
                                                       HorizontalOptions="Center">
                                                        <Label Grid.Column="1"
                                                               Text="Adjust"
                                                               FontAttributes="Bold"
                                                               FontSize="11"
                                                               HorizontalTextAlignment="Center"/>
                                                 </Grid>
                                                 <Grid ColumnDefinitions="24,60,24"
                                                       ColumnSpacing="2"
                                                       HorizontalOptions="Center">
                                                        <Button Text="-"
                                                                WidthRequest="24"
                                                                HeightRequest="24"
                                                                MinimumHeightRequest="24"
                                                                MinimumWidthRequest="24"
                                                                Padding="0"
                                                                FontSize="11"
                                                                CommandParameter="-5"
                                                                Clicked="ResistanceAdjust_Clicked"
                                                                Pressed="ResistanceAdjust_Pressed"
                                                                Released="ResistanceAdjust_Released"/>
                                                        <Border Grid.Column="1"
                                                                Stroke="{AppThemeBinding Light=#D8E0EB, Dark=#2B3544}"
                                                                StrokeShape="RoundRectangle 12"
                                                                Padding="0"
                                                                HorizontalOptions="Center"
                                                                VerticalOptions="Center">
                                                               <Entry Text="{Binding ResistanceAdjustment}"
                                                                      Keyboard="Numeric"
                                                                      BackgroundColor="Transparent"
                                                                      ClearButtonVisibility="Never"
                                                                      HorizontalTextAlignment="Center"
                                                                      HorizontalOptions="Center"
                                                                      VerticalTextAlignment="Center"
                                                                      Margin="0"
                                                                      MaxLength="6"/>
                                                        </Border>
                                                        <Button Grid.Column="2"
                                                                Text="+"
                                                                WidthRequest="24"
                                                                HeightRequest="24"
                                                                MinimumHeightRequest="24"
                                                                MinimumWidthRequest="24"
                                                                Padding="0"
                                                                FontSize="11"
                                                                CommandParameter="5"
                                                                Clicked="ResistanceAdjust_Clicked"
                                                                Pressed="ResistanceAdjust_Pressed"
                                                                Released="ResistanceAdjust_Released"/>
                                                 </Grid>
                                          </VerticalStackLayout>

                                          <VerticalStackLayout Grid.Column="2"
                                                               Spacing="2"
                                                               HorizontalOptions="Center">
                                                 <Grid ColumnDefinitions="22,56,22"
                                                       ColumnSpacing="4"
                                                       HorizontalOptions="Center">
                                                        <Label Grid.Column="1"
                                                               Text="Sets"
                                                               FontAttributes="Bold"
                                                               HorizontalTextAlignment="Center"/>
                                                 </Grid>
                                                 <Grid ColumnDefinitions="22,56,22"
                                                       ColumnSpacing="4"
                                                       HorizontalOptions="Center">
                                                        <Button Text="-"
                                                                Padding="0"
                                                                HeightRequest="24"
                                                                WidthRequest="22"
                                                                MinimumHeightRequest="24"
                                                                MinimumWidthRequest="22"
                                                                FontSize="11"
                                                                IsEnabled="{Binding CanDecreaseSets}"
                                                                Command="{Binding DecreaseSetsCommand}"/>
                                                        <Entry Grid.Column="1"
                                                               Placeholder="1"
                                                               Keyboard="Numeric"
                                                               HorizontalTextAlignment="Center"
                                                               TextChanged="SetsEntry_TextChanged"
                                                               Text="{Binding PlannedSetsInput}"/>
                                                        <Button Grid.Column="2"
                                                                Text="+"
                                                                Padding="0"
                                                                HeightRequest="24"
                                                                WidthRequest="22"
                                                                MinimumHeightRequest="24"
                                                                MinimumWidthRequest="22"
                                                                FontSize="11"
                                                                IsEnabled="{Binding CanIncreaseSets}"
                                                                Command="{Binding IncreaseSetsCommand}"/>
                                                 </Grid>
                                          </VerticalStackLayout>
                                   </Grid>

                                   <Label Text="{Binding WeightHelperText}"
                                          FontSize="11"
                                          TextColor="Gray"
                                          HorizontalOptions="Center"
                                          IsVisible="{Binding HasWeightHelperText}"/>
                                   <Label Text="{Binding WeightTotalPreviewText}"
                                          FontSize="11"
                                          TextColor="Gray"
                                          HorizontalOptions="Center"
                                          IsVisible="{Binding ShowWeightTotalPreview}"/>
                                   <Label Text="{Binding BaseBodyWeightSummary}"
                                          FontSize="12"
                                          TextColor="Gray"
                                          HorizontalOptions="Fill"
                                          HorizontalTextAlignment="Start"
                                          Margin="58,0,0,0"
                                          IsVisible="{Binding ShowResistanceAdjustment}"/>
                                    <Label Text="{Binding EffectiveLoadSummary}"
                                          FontSize="12"
                                          TextColor="Gray"
                                          HorizontalOptions="Fill"
                                          HorizontalTextAlignment="Start"
                                          Margin="58,0,0,0"
                                          IsVisible="{Binding ShowResistanceAdjustment}"/>

                                   <Label Text="{Binding PlannedRepRangeSummary}"
                                          FontSize="11"
                                          TextColor="Gray"
                                          HorizontalOptions="Center"
                                          IsVisible="{Binding HasPlannedRepRange}"/>
                            </VerticalStackLayout>
                     </VerticalStackLayout>

                     <VerticalStackLayout Spacing="8"
                                          HorizontalOptions="Center"
                                          IsVisible="{Binding ShowWorkoutEditor}">
                            <Button Text="Add Workout"
                                    Clicked="OnAddWorkoutClicked"
                                    IsEnabled="{Binding CanAddWorkout}"/>
                            <HorizontalStackLayout Spacing="8"
                                                   HorizontalOptions="Center"
                                                   IsVisible="{Binding ShowStrengthFields}">
                                   <HorizontalStackLayout.GestureRecognizers>
                                          <TapGestureRecognizer Command="{Binding ToggleWarmupSetCommand}"/>
                                   </HorizontalStackLayout.GestureRecognizers>
                                   <CheckBox IsChecked="{Binding IsWarmupSetSelected, Mode=TwoWay}"
                                             IsEnabled="{Binding CanToggleWarmupSet}"
                                             VerticalOptions="Center"/>
                                   <Label Text="Warmup Set"
                                          VerticalOptions="Center"
                                          TextColor="{AppThemeBinding Light=#475569, Dark=#CBD5E1}"/>
                            </HorizontalStackLayout>
                     </VerticalStackLayout>
                     </VerticalStackLayout>
              </ScrollView>
              </Grid>

              <Grid x:Name="InitialBodyWeightOverlay"
                    IsVisible="False"
                    BackgroundColor="#66000000"
                    InputTransparent="False"
                    ZIndex="20">
                     <Grid Padding="24">
                            <Border MaximumWidthRequest="420"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center"
                                    Stroke="{AppThemeBinding Light=#D6DEE8, Dark=#2A3442}"
                                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#141B24}"
                                    StrokeShape="RoundRectangle 24"
                                    Padding="20">
                                   <VerticalStackLayout Spacing="16">
                                          <Grid ColumnDefinitions="*,Auto"
                                                RowDefinitions="Auto,Auto"
                                                RowSpacing="6">
                                                 <Label Grid.Row="0"
                                                        Grid.Column="0"
                                                        Text="Body Weight"
                                                        FontSize="22"
                                                        FontAttributes="Bold" />
                                                 <Button Grid.Row="0"
                                                         Grid.Column="1"
                                                         Text="X"
                                                         Clicked="OnInitialBodyWeightCloseClicked"
                                                         Padding="10,2"
                                                         MinimumWidthRequest="36"
                                                         MinimumHeightRequest="36"
                                                         CornerRadius="18"
                                                         BackgroundColor="{AppThemeBinding Light=#E5EAF1, Dark=#334155}"
                                                         TextColor="{AppThemeBinding Light=#1F2937, Dark=#FFFFFF}" />
                                                 <Label Grid.Row="1"
                                                        Grid.ColumnSpan="2"
                                                        Text="Welcome to Megnor. This is where you can log workouts and start following your plan. If you enter your body weight here, it will save even if you go straight to Workout Plans."
                                                        TextColor="{AppThemeBinding Light=#5A6472, Dark=#A4B2C5}" />
                                          </Grid>

                                          <VerticalStackLayout Spacing="6">
                                                 <Label Text="Weight"
                                                        FontAttributes="Bold"
                                                        FontSize="14" />
                                                 <Entry x:Name="InitialBodyWeightEntry"
                                                        Keyboard="Numeric"
                                                        Placeholder="Weight in lb"
                                                        ClearButtonVisibility="WhileEditing"
                                                        TextChanged="InitialBodyWeightEntry_TextChanged"
                                                        Completed="Entry_Completed"
                                                        MaxLength="6" />
                                                 <Label x:Name="InitialBodyWeightErrorLabel"
                                                        Text="Enter a valid body weight greater than 0."
                                                        FontSize="12"
                                                        TextColor="{AppThemeBinding Light=#C24141, Dark=#F4A4A4}"
                                                        IsVisible="False" />
                                          </VerticalStackLayout>

                                          <Button Text="Go To Workout Plans"
                                                  Clicked="OnInitialBodyWeightWorkoutPlansClicked"
                                                  BackgroundColor="{AppThemeBinding Light=#0F766E, Dark=#14B8A6}"
                                                  TextColor="White" />
                                   </VerticalStackLayout>
                            </Border>
                     </Grid>
              </Grid>
       </Grid>
</ContentPage>
