<?xml version="1.0" encoding="utf-8" ?>
<ContentPage 
    x:Name="Page"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="WorkoutTracker.Views.WorkoutPage"
    Title="Add Workout">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="5">
            <Label Text="Add a Weightlifting Workout" 
                   FontSize="20" 
                   HorizontalOptions="Center" />
            <Label Text="{Binding TodayLabel, StringFormat='Today: {0}'}"
                   FontSize="14"
                   HorizontalOptions="Center"
                   TextColor="Gray" />

            <Border Stroke="{AppThemeBinding Light=#D9E5D2, Dark={StaticResource Gray500}}"
                     StrokeThickness="1"
                     StrokeShape="RoundRectangle 12"
                     BackgroundColor="{AppThemeBinding Light=#F7FBF4, Dark={StaticResource Gray950}}"
                     Padding="14"
                     Margin="0,8,0,12">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Active Plan Suggestions"
                           FontAttributes="Bold"
                           FontSize="18" />

                    <CollectionView ItemsSource="{Binding RecommendedPlanWorkouts}"
                                    x:Name="RecommendationsList"
                                    IsVisible="{Binding HasRecommendedPlanWorkouts}"
                                    SelectionMode="None"
                                    HeightRequest="220">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10"
                                        Margin="0,0,0,8"
                                        Stroke="{AppThemeBinding Light=#C7D8BF, Dark={StaticResource Gray500}}"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}"
                                        StrokeShape="RoundRectangle 8">
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border"
                                                     Binding="{Binding IsSelected}"
                                                     Value="True">
                                            <Setter Property="Stroke" Value="{AppThemeBinding Light=#0F766E, Dark=#14B8A6}" />
                                            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#F0FDFA, Dark=#10211C}" />
                                        </DataTrigger>
                                    </Border.Triggers>
                                    <VerticalStackLayout Spacing="4">
                                        <Grid ColumnDefinitions="*,Auto"
                                              ColumnSpacing="6">
                                            <Label Text="{Binding Workout.Name}"
                                                   FontAttributes="Bold"
                                                   Margin="0"
                                                   VerticalOptions="Center"
                                                   LineBreakMode="WordWrap" />
                                            <Button Grid.Column="1"
                                                    Text="Use This Workout"
                                                    Command="{Binding Source={x:Reference Page}, Path=BindingContext.UseRecommendedWorkoutCommand}"
                                                    CommandParameter="{Binding .}"
                                                    Padding="10,0"
                                                    MinimumHeightRequest="28"
                                                    HeightRequest="28"
                                                    VerticalOptions="Center"
                                                    BackgroundColor="{AppThemeBinding Light=#0F766E, Dark=#14B8A6}"
                                                    TextColor="White"
                                                    CornerRadius="8"
                                                    IsVisible="{Binding ShowUseButton}" />
                                        </Grid>
                                        <Grid ColumnDefinitions="Auto,Auto"
                                              ColumnSpacing="12"
                                              HorizontalOptions="Start"
                                              IsVisible="{Binding ShowDetails}">
                                            <VerticalStackLayout Grid.Column="0"
                                                                 Spacing="1">
                                                <Label Text="{Binding Workout.Sets, StringFormat='Sets: {0}'}"
                                                       FontSize="12"
                                                       TextColor="Gray"
                                                       LineBreakMode="TailTruncation" />
                                                <Label Text="{Binding Workout.Reps, StringFormat='Reps: {0}'}"
                                                       FontSize="12"
                                                       TextColor="Gray"
                                                       LineBreakMode="TailTruncation" />
                                            </VerticalStackLayout>
                                            <VerticalStackLayout Grid.Column="1"
                                                                 Spacing="1">
                                                <Label Text="{Binding LastUsedWeight, StringFormat='Weight: {0}'}"
                                                       FontSize="12"
                                                       TextColor="Gray"
                                                       LineBreakMode="TailTruncation" />
                                                <Label Text="{Binding Workout.MuscleGroup, StringFormat='Focus: {0}'}"
                                                       FontSize="12"
                                                       TextColor="Gray"
                                                       LineBreakMode="TailTruncation" />
                                            </VerticalStackLayout>
                                        </Grid>
                                        <Label Text="{Binding SelectedText}"
                                               FontSize="12"
                                               FontAttributes="Bold"
                                               TextColor="{AppThemeBinding Light=#0F766E, Dark=#7DE6D7}"
                                               IsVisible="{Binding ShowSelectedState}" />
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

            <Border IsVisible="{Binding IsQuickAddMode}"
                    Stroke="#D5DAE1"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 10"
                    Padding="12"
                    Margin="0,0,0,10">
                <Grid RowDefinitions="Auto,Auto" RowSpacing="4">
                    <Label Grid.Row="0"
                           Text="{Binding Name}"
                           FontAttributes="Bold"
                           FontSize="16"
                           IsVisible="{Binding ShowQuickAddReadOnlySummary}" />
                    <Entry Grid.Row="0"
                           Text="{Binding Name}"
                           FontAttributes="Bold"
                           FontSize="16"
                           IsVisible="{Binding ShowQuickAddInlineEditors}" />
                    <Grid Grid.Row="1"
                          ColumnDefinitions="Auto,Auto"
                          ColumnSpacing="12"
                          HorizontalOptions="Start"
                          IsVisible="{Binding ShowQuickAddReadOnlySummary}">
                        <VerticalStackLayout Grid.Column="0"
                                             Spacing="1">
                            <Label Text="{Binding Sets, StringFormat='Sets: {0}'}"
                                   FontSize="12"
                                   TextColor="Gray" />
                            <Label Text="{Binding Reps, StringFormat='Reps: {0}'}"
                                   FontSize="12"
                                   TextColor="Gray" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1"
                                             Spacing="1">
                            <Label Text="{Binding Weight, StringFormat='Weight: {0}'}"
                                   FontSize="12"
                                   TextColor="Gray" />
                            <Label Text="{Binding SelectedMuscleGroup, StringFormat='Focus: {0}'}"
                                   FontSize="12"
                                   TextColor="Gray" />
                        </VerticalStackLayout>
                    </Grid>
                    <Grid Grid.Row="1"
                          ColumnDefinitions="Auto,Auto"
                          ColumnSpacing="12"
                          HorizontalOptions="Start"
                          IsVisible="{Binding ShowQuickAddInlineEditors}">
                        <Grid Grid.Column="0"
                              RowDefinitions="Auto,Auto"
                              RowSpacing="4">
                            <Grid Grid.Row="0"
                                  ColumnDefinitions="Auto,*"
                                  ColumnSpacing="4">
                                <Label Text="Sets:"
                                       FontSize="12"
                                       TextColor="Gray"
                                       VerticalOptions="Center" />
                                <Entry Grid.Column="1"
                                       Text="{Binding Sets}"
                                       Placeholder="0"
                                       Keyboard="Numeric"
                                       FontSize="12"
                                       WidthRequest="44" />
                                <Label Grid.Column="2"
                                       Text="Reps:"
                                       FontSize="12"
                                       TextColor="Gray"
                                       VerticalOptions="Center"
                                       IsVisible="False" />
                            </Grid>
                            <Grid Grid.Row="1"
                                  ColumnDefinitions="Auto,*"
                                  ColumnSpacing="4">
                                <Label Text="Reps:"
                                       FontSize="12"
                                       TextColor="Gray"
                                       VerticalOptions="Center" />
                                <Entry Grid.Column="1"
                                       Text="{Binding Reps}"
                                       Placeholder="0"
                                       Keyboard="Numeric"
                                       FontSize="12"
                                       WidthRequest="44" />
                            </Grid>
                        </Grid>
                        <Grid Grid.Column="1"
                              RowDefinitions="Auto,Auto"
                              RowSpacing="4">
                            <Grid Grid.Row="0"
                                  ColumnDefinitions="Auto,*"
                                  ColumnSpacing="4">
                                <Label Text="Weight:"
                                       FontSize="12"
                                       TextColor="Gray"
                                       VerticalOptions="Center"
                                       IsVisible="{Binding ShowStandardWeightInput}" />
                                <Entry Grid.Column="1"
                                       Text="{Binding Weight}"
                                       Placeholder="0"
                                       Keyboard="Numeric"
                                       FontSize="12"
                                       WidthRequest="70"
                                       IsVisible="{Binding ShowStandardWeightInput}" />
                                <Grid Grid.ColumnSpan="2"
                                      ColumnDefinitions="36,76,36"
                                      ColumnSpacing="6"
                                      HorizontalOptions="Start"
                                      IsVisible="{Binding ShowResistanceAdjustment}">
                                    <Button Text="-"
                                            WidthRequest="36"
                                            HeightRequest="36"
                                            CommandParameter="-5"
                                            Clicked="ResistanceAdjust_Clicked"
                                            Pressed="ResistanceAdjust_Pressed"
                                            Released="ResistanceAdjust_Released" />
                                    <Border Grid.Column="1"
                                            Stroke="{AppThemeBinding Light=#D8E0EB, Dark=#2B3544}"
                                            StrokeShape="RoundRectangle 10"
                                            Padding="0"
                                            VerticalOptions="Center">
                                        <Entry Text="{Binding ResistanceAdjustment}"
                                               Keyboard="Numeric"
                                               BackgroundColor="Transparent"
                                               ClearButtonVisibility="Never"
                                               FontSize="12"
                                               HorizontalTextAlignment="Center"
                                               VerticalTextAlignment="Center"
                                               Margin="0"
                                               MaxLength="6" />
                                    </Border>
                                    <Button Grid.Column="2"
                                            Text="+"
                                            WidthRequest="36"
                                            HeightRequest="36"
                                            CommandParameter="5"
                                            Clicked="ResistanceAdjust_Clicked"
                                            Pressed="ResistanceAdjust_Pressed"
                                            Released="ResistanceAdjust_Released" />
                                </Grid>
                            </Grid>
                            <Grid Grid.Row="1"
                                  ColumnDefinitions="Auto,*"
                                  ColumnSpacing="4">
                                <Label Text="Focus:"
                                       FontSize="12"
                                       TextColor="Gray"
                                       VerticalOptions="Center" />
                                <Picker Grid.Column="1"
                                        Title="Select Muscle Group"
                                        FontSize="12"
                                        WidthRequest="110"
                                        ItemsSource="{Binding MuscleGroups}"
                                        SelectedItem="{Binding SelectedMuscleGroup}" />
                            </Grid>
                        </Grid>
                    </Grid>
                    <ImageButton Grid.RowSpan="2"
                                 Source="edit_icon.png"
                                 BackgroundColor="Transparent"
                                 HeightRequest="16"
                                 WidthRequest="16"
                                 Padding="0"
                                 Margin="0"
                                 HorizontalOptions="End"
                                 VerticalOptions="Center"
                                 ZIndex="10"
                                 Command="{Binding ToggleAdvancedFieldsCommand}" />
                </Grid>
            </Border>

            <VerticalStackLayout Spacing="2"
                                 IsVisible="{Binding ShowStandaloneWeightField}">
                <Label Text="Weight"
                       FontAttributes="Bold"
                       IsVisible="{Binding ShowStandardWeightInput}" />
                <Entry x:Name="WeightEntry"
                       Placeholder="Enter weight (lbs or kg)" 
                       Keyboard="Numeric" 
                       Text="{Binding Weight}"
                       IsVisible="{Binding ShowStandardWeightInput}" />
                <Label Text="{Binding BaseBodyWeightSummary}"
                       FontSize="12"
                       TextColor="Gray"
                       HorizontalOptions="Fill"
                       HorizontalTextAlignment="Start"
                       Margin="78,0,0,0"
                       IsVisible="{Binding ShowResistanceAdjustment}" />
                <Label Text="Adjustment (+ resistance / - assistance)"
                       FontAttributes="Bold"
                       FontSize="12"
                       HorizontalOptions="Fill"
                       HorizontalTextAlignment="Start"
                       Margin="78,0,0,0"
                       IsVisible="{Binding ShowResistanceAdjustment}" />
                <Grid ColumnDefinitions="42,92,42"
                      ColumnSpacing="10"
                      HorizontalOptions="Center"
                      IsVisible="{Binding ShowResistanceAdjustment}">
                    <Button Text="-"
                            WidthRequest="42"
                            HeightRequest="42"
                            CommandParameter="-5"
                            Clicked="ResistanceAdjust_Clicked"
                            Pressed="ResistanceAdjust_Pressed"
                            Released="ResistanceAdjust_Released" />
                    <Border Grid.Column="1"
                            Stroke="{AppThemeBinding Light=#D8E0EB, Dark=#2B3544}"
                            StrokeShape="RoundRectangle 12"
                            Padding="0"
                            HorizontalOptions="Center"
                            VerticalOptions="Center">
                        <Entry Text="{Binding ResistanceAdjustment}"
                               Keyboard="Numeric"
                               BackgroundColor="Transparent"
                               ClearButtonVisibility="Never"
                               HorizontalTextAlignment="Center"
                               HorizontalOptions="Center"
                               VerticalTextAlignment="Center"
                               Margin="0"
                               MaxLength="6" />
                    </Border>
                    <Button Grid.Column="2"
                            Text="+"
                            WidthRequest="42"
                            HeightRequest="42"
                            CommandParameter="5"
                            Clicked="ResistanceAdjust_Clicked"
                            Pressed="ResistanceAdjust_Pressed"
                            Released="ResistanceAdjust_Released" />
                </Grid>
                <Label Text="{Binding EffectiveLoadSummary}"
                       FontSize="12"
                       TextColor="Gray"
                       HorizontalOptions="Fill"
                       HorizontalTextAlignment="Start"
                       Margin="78,0,0,0"
                       IsVisible="{Binding ShowResistanceAdjustment}" />
            </VerticalStackLayout>

            <VerticalStackLayout IsVisible="{Binding ShowAdvancedEditorSection}"
                                   Spacing="5">
                <VerticalStackLayout Spacing="2">
                    <Label Text="Focus" FontAttributes="Bold" />
                    <Picker Title="Select Muscle Group"
                            ItemsSource="{Binding MuscleGroups}"
                            SelectedItem="{Binding SelectedMuscleGroup}" />
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="2">
                    <Label Text="Exercise" FontAttributes="Bold" />
                    <Entry x:Name="ExerciseEntry"
                           Placeholder="Type exercise name..."
                           Text="{Binding ExerciseSearchQuery}" 
                           Focused="ExerciseEntry_Focused"
                           Unfocused="ExerciseEntry_Unfocused" />
                </VerticalStackLayout>

                <!-- CollectionView for suggestions -->
                <CollectionView ItemsSource="{Binding ExerciseSuggestions}"
                                IsVisible="{Binding IsNameFieldFocused}"
                                SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10" Margin="5" Stroke="LightGray" StrokeShape="RoundRectangle 5">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer 
                                        Command="{Binding Source={x:Reference Page}, Path=BindingContext.SelectExerciseCommand}"
                                        CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                                <Label Text="{Binding Name}" />
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <VerticalStackLayout Spacing="2">
                    <Label Text="Reps" FontAttributes="Bold" />
                    <Entry x:Name="RepsEntry"
                           Placeholder="Enter reps" 
                           Keyboard="Numeric" 
                           Text="{Binding Reps}" />
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="2">
                    <Label Text="Sets" FontAttributes="Bold" />
                    <Entry x:Name="SetsEntry"
                           Placeholder="Enter sets" 
                           Keyboard="Numeric" 
                           Text="{Binding Sets}" />
                </VerticalStackLayout>
            </VerticalStackLayout>

            <Button Text="Add Workout" 
                    Clicked="OnAddWorkoutClicked"
                    HorizontalOptions="Center" />
            <Button
                    Text="View Workouts"
                    Command="{Binding NavigateToViewWorkoutsCommand}"
                    IsVisible="{Binding HasWorkouts}"
                    HorizontalOptions="Center" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
