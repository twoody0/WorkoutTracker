<?xml version="1.0" encoding="utf-8" ?>
<ContentPage 
    x:Name="Page"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="WorkoutTracker.Views.WorkoutPage"
    Title="Add Workout">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="5">
            <Label Text="Add a Weightlifting Workout" 
                   FontSize="20" 
                   HorizontalOptions="Center" />
            <Label Text="{Binding TodayLabel, StringFormat='Today: {0}'}"
                   FontSize="14"
                   HorizontalOptions="Center"
                   TextColor="Gray" />

            <Border Stroke="#D9E5D2"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 12"
                    BackgroundColor="#F7FBF4"
                    Padding="14"
                    Margin="0,8,0,12">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Active Plan Suggestions"
                           FontAttributes="Bold"
                           FontSize="18" />
                    <Label Text="{Binding ActivePlanSummary}"
                           TextColor="#4F5B4B" />

                    <CollectionView ItemsSource="{Binding RecommendedPlanWorkouts}"
                                    IsVisible="{Binding HasRecommendedPlanWorkouts}"
                                    SelectionMode="None"
                                    HeightRequest="220">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10"
                                        Margin="0,0,0,8"
                                        Stroke="#C7D8BF"
                                        StrokeShape="RoundRectangle 8">
                                    <VerticalStackLayout Spacing="4">
                                        <Label Text="{Binding Name}" FontAttributes="Bold" />
                                        <Label Text="{Binding MuscleGroup, StringFormat='Focus: {0}'}"
                                               FontSize="12"
                                               TextColor="Gray" />
                                        <Label Text="{Binding Sets, StringFormat='Sets: {0}'}"
                                               FontSize="12"
                                               TextColor="Gray" />
                                        <Label Text="{Binding Reps, StringFormat='Reps: {0}'}"
                                               FontSize="12"
                                               TextColor="Gray" />
                                        <Button Text="Use This Workout"
                                                Command="{Binding Source={x:Reference Page}, Path=BindingContext.UseRecommendedWorkoutCommand}"
                                                CommandParameter="{Binding .}"
                                                BackgroundColor="#DDEFD2"
                                                TextColor="#183A1D"
                                                CornerRadius="8" />
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

            <!-- Muscle Group Picker -->
            <Picker Title="Select Muscle Group"
                    ItemsSource="{Binding MuscleGroups}"
                    SelectedItem="{Binding SelectedMuscleGroup}" />

            <!-- Entry for exercise name search -->
            <Entry x:Name="ExerciseEntry"
                   Placeholder="Type exercise name..."
                   Text="{Binding ExerciseSearchQuery}" 
                   Focused="ExerciseEntry_Focused"
                   Unfocused="ExerciseEntry_Unfocused" />

            <!-- CollectionView for suggestions -->
            <CollectionView ItemsSource="{Binding ExerciseSuggestions}"
                            IsVisible="{Binding IsNameFieldFocused}"
                            SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="10" Margin="5" Stroke="LightGray" StrokeShape="RoundRectangle 5">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer 
                                    Command="{Binding Source={x:Reference Page}, Path=BindingContext.SelectExerciseCommand}"
                                    CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>
                            <Label Text="{Binding Name}" />
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Fields for weight, reps, and sets -->
            <Entry x:Name="WeightEntry"
                   Placeholder="Enter weight (lbs or kg)" 
                   Keyboard="Numeric" 
                   Text="{Binding Weight}" />

            <Entry x:Name="RepsEntry"
                   Placeholder="Enter reps" 
                   Keyboard="Numeric" 
                   Text="{Binding Reps}" />

            <Entry x:Name="SetsEntry"
                   Placeholder="Enter sets" 
                   Keyboard="Numeric" 
                   Text="{Binding Sets}" />

            <Button Text="Add Workout" 
                    Clicked="OnAddWorkoutClicked"
                    HorizontalOptions="Center" />
            <Button
                    Text="View Workouts"
                    Command="{Binding NavigateToViewWorkoutsCommand}"
                    IsVisible="{Binding HasWorkouts}"
                    HorizontalOptions="Center" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
