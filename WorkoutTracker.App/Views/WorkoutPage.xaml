<?xml version="1.0" encoding="utf-8" ?>
<ContentPage 
    x:Name="Page"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="WorkoutTracker.Views.WorkoutPage"
    Title="Add Workout">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="5">
            <Label Text="Add a Weightlifting Workout" 
                   FontSize="20" 
                   HorizontalOptions="Center" />
            <Label Text="{Binding TodayLabel, StringFormat='Today: {0}'}"
                   FontSize="14"
                   HorizontalOptions="Center"
                   TextColor="Gray" />

            <Border Stroke="{AppThemeBinding Light=#D9E5D2, Dark={StaticResource Gray500}}"
                     StrokeThickness="1"
                     StrokeShape="RoundRectangle 12"
                     BackgroundColor="{AppThemeBinding Light=#F7FBF4, Dark={StaticResource Gray950}}"
                     Padding="14"
                     Margin="0,8,0,12">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Active Plan Suggestions"
                           FontAttributes="Bold"
                           FontSize="18" />

                    <CollectionView ItemsSource="{Binding RecommendedPlanWorkouts}"
                                    x:Name="RecommendationsList"
                                    IsVisible="{Binding HasRecommendedPlanWorkouts}"
                                    SelectionMode="None"
                                    HeightRequest="220">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10"
                                        Margin="0,0,0,8"
                                        Stroke="{AppThemeBinding Light=#C7D8BF, Dark={StaticResource Gray500}}"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}"
                                        StrokeShape="RoundRectangle 8">
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border"
                                                     Binding="{Binding IsSelected}"
                                                     Value="True">
                                            <Setter Property="Stroke" Value="{AppThemeBinding Light=#0F766E, Dark=#14B8A6}" />
                                            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#F0FDFA, Dark=#10211C}" />
                                        </DataTrigger>
                                    </Border.Triggers>
                                    <VerticalStackLayout Spacing="4">
                                        <Grid ColumnDefinitions="*,Auto"
                                              ColumnSpacing="10">
                                            <Label Text="{Binding Workout.Name}"
                                                   FontAttributes="Bold"
                                                   Margin="0"
                                                   VerticalOptions="Center"
                                                   LineBreakMode="WordWrap" />
                                            <Button Grid.Column="1"
                                                    Text="Use This Workout"
                                                    Command="{Binding Source={x:Reference Page}, Path=BindingContext.UseRecommendedWorkoutCommand}"
                                                    CommandParameter="{Binding .}"
                                                    Padding="10,0"
                                                    MinimumHeightRequest="28"
                                                    HeightRequest="28"
                                                    VerticalOptions="Center"
                                                    BackgroundColor="{AppThemeBinding Light=#0F766E, Dark=#14B8A6}"
                                                    TextColor="White"
                                                    CornerRadius="8"
                                                    IsVisible="{Binding ShowUseButton}" />
                                        </Grid>
                                        <Label Text="{Binding Workout.MuscleGroup, StringFormat='Focus: {0}'}"
                                                FontSize="12"
                                                TextColor="Gray"
                                                LineBreakMode="WordWrap"
                                                IsVisible="{Binding ShowDetails}" />
                                        <Label Text="{Binding LastUsedWeight, StringFormat='Weight: {0}'}"
                                               FontSize="12"
                                               TextColor="Gray"
                                               LineBreakMode="WordWrap"
                                               IsVisible="{Binding ShowDetails}" />
                                        <Label Text="{Binding Workout.Sets, StringFormat='Sets: {0}'}"
                                               FontSize="12"
                                               TextColor="Gray"
                                               LineBreakMode="WordWrap"
                                               IsVisible="{Binding ShowDetails}" />
                                        <Label Text="{Binding Workout.Reps, StringFormat='Reps: {0}'}"
                                               FontSize="12"
                                               TextColor="Gray"
                                               LineBreakMode="WordWrap"
                                               IsVisible="{Binding ShowDetails}" />
                                        <Label Text="{Binding SelectedText}"
                                               FontSize="12"
                                               FontAttributes="Bold"
                                               TextColor="{AppThemeBinding Light=#0F766E, Dark=#7DE6D7}"
                                               IsVisible="{Binding ShowSelectedState}" />
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

            <Border IsVisible="{Binding IsQuickAddMode}"
                    Stroke="#D5DAE1"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 10"
                    Padding="12"
                    Margin="0,0,0,10">
                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="4">
                    <Label Grid.Row="0"
                           Grid.Column="0"
                           Text="{Binding Name}"
                           FontAttributes="Bold"
                           FontSize="16"
                           IsVisible="{Binding ShowQuickAddReadOnlySummary}" />
                    <Entry Grid.Row="0"
                           Grid.Column="0"
                           Text="{Binding Name}"
                           FontAttributes="Bold"
                           FontSize="16"
                           IsVisible="{Binding ShowQuickAddInlineEditors}" />
                    <Label Grid.Row="1"
                           Grid.Column="0"
                           Text="{Binding Weight, StringFormat='Weight: {0}'}"
                           FontSize="12"
                           TextColor="Gray"
                           IsVisible="{Binding ShowQuickAddReadOnlySummary}" />
                    <Grid Grid.Row="1"
                          Grid.Column="0"
                          ColumnDefinitions="Auto,*"
                          ColumnSpacing="6"
                          IsVisible="{Binding ShowQuickAddInlineEditors}">
                        <Label Text="Weight:"
                               FontSize="12"
                               TextColor="Gray"
                               VerticalOptions="Center" />
                        <Entry Grid.Column="1"
                               Text="{Binding Weight}"
                               Placeholder="0"
                               Keyboard="Numeric"
                               FontSize="12" />
                    </Grid>
                    <Label Grid.Row="2"
                           Grid.Column="0"
                           Text="{Binding SelectedMuscleGroup, StringFormat='Focus: {0}'}"
                           FontSize="12"
                           TextColor="Gray"
                           IsVisible="{Binding ShowQuickAddReadOnlySummary}" />
                    <Grid Grid.Row="2"
                          Grid.Column="0"
                          ColumnDefinitions="Auto,*"
                          ColumnSpacing="6"
                          IsVisible="{Binding ShowQuickAddInlineEditors}">
                        <Label Text="Focus:"
                               FontSize="12"
                               TextColor="Gray"
                               VerticalOptions="Center" />
                        <Picker Grid.Column="1"
                                Title="Select Muscle Group"
                                FontSize="12"
                                ItemsSource="{Binding MuscleGroups}"
                                SelectedItem="{Binding SelectedMuscleGroup}" />
                    </Grid>
                    <Label Grid.Row="3"
                           Grid.Column="0"
                           Text="{Binding Sets, StringFormat='Sets: {0}'}"
                           FontSize="12"
                           TextColor="Gray"
                           IsVisible="{Binding ShowQuickAddReadOnlySummary}" />
                    <Grid Grid.Row="3"
                          Grid.Column="0"
                          ColumnDefinitions="Auto,*"
                          ColumnSpacing="6"
                          IsVisible="{Binding ShowQuickAddInlineEditors}">
                        <Label Text="Sets:"
                               FontSize="12"
                               TextColor="Gray"
                               VerticalOptions="Center" />
                        <Entry Grid.Column="1"
                               Text="{Binding Sets}"
                               Placeholder="0"
                               Keyboard="Numeric"
                               FontSize="12" />
                    </Grid>
                    <Label Grid.Row="4"
                           Grid.Column="0"
                           Text="{Binding Reps, StringFormat='Reps: {0}'}"
                           FontSize="12"
                           TextColor="Gray"
                           IsVisible="{Binding ShowQuickAddReadOnlySummary}" />
                    <Grid Grid.Row="4"
                          Grid.Column="0"
                          ColumnDefinitions="Auto,*"
                          ColumnSpacing="6"
                          IsVisible="{Binding ShowQuickAddInlineEditors}">
                        <Label Text="Reps:"
                               FontSize="12"
                               TextColor="Gray"
                               VerticalOptions="Center" />
                        <Entry Grid.Column="1"
                               Text="{Binding Reps}"
                               Placeholder="0"
                               Keyboard="Numeric"
                               FontSize="12" />
                    </Grid>
                    <ImageButton Grid.RowSpan="5"
                                  Grid.Column="1"
                                  Source="edit_icon.png"
                                  BackgroundColor="Transparent"
                                 HeightRequest="24"
                                 WidthRequest="24"
                                 Command="{Binding ToggleAdvancedFieldsCommand}" />
                </Grid>
            </Border>

            <VerticalStackLayout Spacing="2"
                                 IsVisible="{Binding ShowStandaloneWeightField}">
                <Label Text="Weight" FontAttributes="Bold" />
                <Entry x:Name="WeightEntry"
                       Placeholder="Enter weight (lbs or kg)" 
                       Keyboard="Numeric" 
                       Text="{Binding Weight}" />
            </VerticalStackLayout>

            <VerticalStackLayout IsVisible="{Binding ShowAdvancedEditorSection}"
                                   Spacing="5">
                <VerticalStackLayout Spacing="2">
                    <Label Text="Focus" FontAttributes="Bold" />
                    <Picker Title="Select Muscle Group"
                            ItemsSource="{Binding MuscleGroups}"
                            SelectedItem="{Binding SelectedMuscleGroup}" />
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="2">
                    <Label Text="Exercise" FontAttributes="Bold" />
                    <Entry x:Name="ExerciseEntry"
                           Placeholder="Type exercise name..."
                           Text="{Binding ExerciseSearchQuery}" 
                           Focused="ExerciseEntry_Focused"
                           Unfocused="ExerciseEntry_Unfocused" />
                </VerticalStackLayout>

                <!-- CollectionView for suggestions -->
                <CollectionView ItemsSource="{Binding ExerciseSuggestions}"
                                IsVisible="{Binding IsNameFieldFocused}"
                                SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10" Margin="5" Stroke="LightGray" StrokeShape="RoundRectangle 5">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer 
                                        Command="{Binding Source={x:Reference Page}, Path=BindingContext.SelectExerciseCommand}"
                                        CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                                <Label Text="{Binding Name}" />
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <VerticalStackLayout Spacing="2">
                    <Label Text="Reps" FontAttributes="Bold" />
                    <Entry x:Name="RepsEntry"
                           Placeholder="Enter reps" 
                           Keyboard="Numeric" 
                           Text="{Binding Reps}" />
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="2">
                    <Label Text="Sets" FontAttributes="Bold" />
                    <Entry x:Name="SetsEntry"
                           Placeholder="Enter sets" 
                           Keyboard="Numeric" 
                           Text="{Binding Sets}" />
                </VerticalStackLayout>
            </VerticalStackLayout>

            <Button Text="Add Workout" 
                    Clicked="OnAddWorkoutClicked"
                    HorizontalOptions="Center" />
            <Button
                    Text="View Workouts"
                    Command="{Binding NavigateToViewWorkoutsCommand}"
                    IsVisible="{Binding HasWorkouts}"
                    HorizontalOptions="Center" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
