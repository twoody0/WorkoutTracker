<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:WorkoutTracker.ViewModels"
             x:Class="WorkoutTracker.Views.WorkoutPlanDetailsPage"
             Title="{Binding SelectedPlan.Name}">

    <ScrollView>
        <VerticalStackLayout Padding="20,18,20,28" Spacing="15">
            <Label Text="{Binding SelectedPlan.DurationDisplay, StringFormat='Duration: {0}'}"
                   FontSize="14"
                   TextColor="{AppThemeBinding Light=#0F766E, Dark=#7DE6D7}" />
            <Label Text="{Binding SelectedPlan.Description}"
                   FontSize="16"
                   TextColor="{AppThemeBinding Light=#667384, Dark=#A2B0C2}" />

            <VerticalStackLayout Spacing="6"
                                 IsVisible="{Binding ShowWeekSelector}">
                <HorizontalStackLayout Spacing="8">
                    <Label Text="Week:"
                           FontSize="13"
                           FontAttributes="Bold"
                           VerticalOptions="Center"
                           TextColor="{AppThemeBinding Light=#244B58, Dark=#C3D7E7}" />
                    <Picker ItemsSource="{Binding PreviewWeeks}"
                            SelectedItem="{Binding SelectedPreviewWeek}"
                            Title="Choose a week"
                            HorizontalOptions="FillAndExpand" />
                    <ImageButton Source="info.png"
                                 HeightRequest="20"
                                 WidthRequest="20"
                                 Padding="0"
                                 BackgroundColor="Transparent"
                                 Command="{Binding ToggleWeekTemplateHelpCommand}" />
                </HorizontalStackLayout>
                <Border Stroke="{AppThemeBinding Light=#D8E0EB, Dark=#2B3544}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 12"
                        BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#101720}"
                        Padding="12,10"
                        IsVisible="{Binding ShowWeekTemplateHelp}">
                    <Label Text="{Binding WeekTemplateHelpText}"
                           FontSize="12"
                           TextColor="{AppThemeBinding Light=#667384, Dark=#A2B0C2}" />
                </Border>
                <Label Text="{Binding PreviewWeekSummary}"
                       FontSize="13"
                       TextColor="{AppThemeBinding Light=#0F766E, Dark=#7DE6D7}" />
                <HorizontalStackLayout Spacing="8"
                                       IsVisible="{Binding ShowRpeInfo}">
                    <Label Text="Target RPE guidance"
                           FontSize="13"
                           FontAttributes="Bold"
                           VerticalOptions="Center"
                           TextColor="{AppThemeBinding Light=#244B58, Dark=#C3D7E7}" />
                    <ImageButton Source="info.png"
                                 HeightRequest="18"
                                 WidthRequest="18"
                                 Padding="0"
                                 BackgroundColor="Transparent"
                                 Command="{Binding ToggleRpeHelpCommand}" />
                </HorizontalStackLayout>
                <Border Stroke="{AppThemeBinding Light=#D8E0EB, Dark=#2B3544}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 12"
                        BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#101720}"
                        Padding="12,10"
                        IsVisible="{Binding ShowRpeHelp}">
                    <Label Text="{Binding RpeHelpText}"
                           FontSize="12"
                           TextColor="{AppThemeBinding Light=#667384, Dark=#A2B0C2}" />
                </Border>
            </VerticalStackLayout>

            <Border IsVisible="{Binding SelectedPlan.IsCustom}"
                    Stroke="{AppThemeBinding Light=#D8E0EB, Dark=#2B3544}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 16"
                    BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#101720}"
                    Padding="14,12">
                <Label Text="Tap Add Workout on any day to build out your week, then come back here to review the full plan."
                       FontSize="13"
                       TextColor="{AppThemeBinding Light=#667384, Dark=#A2B0C2}" />
            </Border>

            <Button Text="Start Plan"
                    Command="{Binding StartPlanCommand}"
                    IsVisible="{Binding ShowStartPlanButton}"
                    BackgroundColor="{AppThemeBinding Light=#0F766E, Dark=#14B8A6}"
                    TextColor="White"
                    CornerRadius="12" />

            <VerticalStackLayout Spacing="12"
                                 BindableLayout.ItemsSource="{Binding WorkoutGroups}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate>
                        <VerticalStackLayout Spacing="10">
                            <Border Stroke="{AppThemeBinding Light=#D8E0EB, Dark=#2B3544}"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 18"
                                    BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#101720}"
                                    Padding="14,12">
                                <VerticalStackLayout Spacing="10">
                                    <Grid ColumnDefinitions="Auto,*,Auto"
                                          ColumnSpacing="12">
                                        <Grid.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:WorkoutPlanDetailsViewModel}}, Path=ToggleExpandCommand}"
                                                                  CommandParameter="{Binding .}" />
                                        </Grid.GestureRecognizers>
                                        <Label Text="{Binding ToggleGlyph}"
                                               FontSize="18"
                                               VerticalOptions="Center"
                                               IsVisible="{Binding HasWorkouts}"
                                               TextColor="{AppThemeBinding Light=#0F766E, Dark=#7DE6D7}" />
                                        <VerticalStackLayout Grid.Column="1" Spacing="4">
                                            <Label Text="{Binding DayLabel}"
                                                   FontSize="18"
                                                   FontAttributes="Bold"
                                                   TextColor="{AppThemeBinding Light=#244B58, Dark=#C3D7E7}" />
                                            <Label Text="{Binding MuscleGroupSummary}"
                                                   FontSize="13"
                                                   LineBreakMode="WordWrap"
                                                   MaxLines="3"
                                                   TextColor="{AppThemeBinding Light=#0F766E, Dark=#7DE6D7}"
                                                   IsVisible="{Binding HasWorkouts}" />
                                            <Label Text="{Binding WorkoutCountLabel}"
                                                   FontSize="12"
                                                   TextColor="{AppThemeBinding Light=#667384, Dark=#A2B0C2}" />
                                        </VerticalStackLayout>
                                        <Button Grid.Column="2"
                                                Text="{Binding DayActionText}"
                                                Padding="12,6"
                                                VerticalOptions="Center"
                                                IsVisible="{Binding CanEditDay}"
                                                BackgroundColor="{AppThemeBinding Light=#E6EFFC, Dark=#1D324B}"
                                                TextColor="{AppThemeBinding Light=#1D4ED8, Dark=#93C5FD}"
                                                CornerRadius="12"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:WorkoutPlanDetailsViewModel}}, Path=EditDayCommand}"
                                                CommandParameter="{Binding .}" />
                                    </Grid>

                                    <VerticalStackLayout Spacing="10"
                                                          IsVisible="{Binding IsExpanded}"
                                                          BindableLayout.ItemsSource="{Binding VisibleMuscleGroups}">
                                        <BindableLayout.ItemTemplate>
                                            <DataTemplate>
                                                <VerticalStackLayout Spacing="8">
                                                    <Label Text="{Binding MuscleGroupLabel, StringFormat='Muscle Group: {0}'}"
                                                           FontSize="14"
                                                           FontAttributes="Bold"
                                                           TextColor="{AppThemeBinding Light=#0F766E, Dark=#7DE6D7}" />

                                                    <VerticalStackLayout Spacing="10"
                                                                         BindableLayout.ItemsSource="{Binding Workouts}">
                                                        <BindableLayout.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Stroke="{AppThemeBinding Light=#D8E0EB, Dark=#2B3544}"
                                                                        StrokeThickness="1"
                                                                        StrokeShape="RoundRectangle 18"
                                                                        BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#141B24}"
                                                                        Padding="12">
                                                                    <VerticalStackLayout Spacing="4">
                                                                        <Label Text="{Binding Workout.Name}" FontAttributes="Bold" FontSize="16" />

                                                                        <StackLayout IsVisible="{Binding Workout.Type, Converter={StaticResource IsWeightLiftingConverter}}">
                                                                            <Label Text="{Binding Workout.Sets, StringFormat='Sets: {0}'}" FontSize="14" />
                                                                            <Label Text="{Binding Workout.RepDisplay, StringFormat='Reps: {0}'}" FontSize="14" />
                                                                            <Label Text="{Binding Workout.TargetRpeDisplay, StringFormat='Target RPE: {0}'}"
                                                                                   FontSize="14"
                                                                                   IsVisible="{Binding Workout.HasTargetRpe}" />
                                                                            <Label Text="{Binding Workout.TargetRestRange, StringFormat='Target rest: {0}'}"
                                                                                   FontSize="14"
                                                                                   IsVisible="{Binding Workout.HasTargetRestRange}" />
                                                                        </StackLayout>

                                                                        <StackLayout IsVisible="{Binding Workout.Type, Converter={StaticResource IsCardioConverter}}">
                                                                            <Label Text="{Binding Workout.DurationMinutes, StringFormat='Time: {0} min'}"
                                                                                   FontSize="14"
                                                                                   IsVisible="{Binding Workout.HasDuration}" />
                                                                            <Label Text="{Binding Workout.DistanceMiles, StringFormat='Distance: {0:F1} mi'}"
                                                                                   FontSize="14"
                                                                                   IsVisible="{Binding Workout.HasDistance}" />
                                                                            <Label Text="{Binding Workout.TargetRpeDisplay, StringFormat='Target RPE: {0}'}"
                                                                                   FontSize="14"
                                                                                   IsVisible="{Binding Workout.HasTargetRpe}" />
                                                                            <Label Text="{Binding Workout.Steps, StringFormat='Tracked steps: {0}'}"
                                                                                   FontSize="14"
                                                                                   IsVisible="{Binding Workout.HasSteps}" />
                                                                        </StackLayout>
                                                                    </VerticalStackLayout>
                                                                </Border>
                                                            </DataTemplate>
                                                        </BindableLayout.ItemTemplate>
                                                    </VerticalStackLayout>
                                                </VerticalStackLayout>
                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                    </VerticalStackLayout>

                                    <Label Text="{Binding RestDayMessage}"
                                           IsVisible="{Binding ShowRestDayMessage}"
                                           FontSize="14"
                                           TextColor="{AppThemeBinding Light=#667384, Dark=#A2B0C2}" />
                                </VerticalStackLayout>
                            </Border>
                        </VerticalStackLayout>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
