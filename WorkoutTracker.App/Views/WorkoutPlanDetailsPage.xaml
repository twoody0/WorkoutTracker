<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:WorkoutTracker.ViewModels"
             x:Class="WorkoutTracker.Views.WorkoutPlanDetailsPage"
             Title="{Binding SelectedPlan.Name}">

    <ScrollView>
        <VerticalStackLayout Padding="20,18,20,28" Spacing="15">
            <Label Text="{Binding SelectedPlan.DurationDisplay, StringFormat='Duration: {0}'}"
                   FontSize="14"
                   TextColor="{AppThemeBinding Light=#0F766E, Dark=#7DE6D7}" />
            <Label Text="{Binding SelectedPlan.Description}"
                   FontSize="16"
                   TextColor="{AppThemeBinding Light=#667384, Dark=#A2B0C2}" />

            <Button Text="Start Plan"
                    Command="{Binding StartPlanCommand}"
                    BackgroundColor="{AppThemeBinding Light=#0F766E, Dark=#14B8A6}"
                    TextColor="White"
                    CornerRadius="12" />

            <VerticalStackLayout Spacing="12"
                                 BindableLayout.ItemsSource="{Binding WorkoutGroups}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate>
                        <VerticalStackLayout Spacing="10">
                            <Label Text="{Binding Day}"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#244B58, Dark=#C3D7E7}" />

                            <VerticalStackLayout Spacing="10"
                                                 BindableLayout.ItemsSource="{Binding Workouts}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate>
                                        <Border Stroke="{AppThemeBinding Light=#D8E0EB, Dark=#2B3544}"
                                                StrokeThickness="1"
                                                StrokeShape="RoundRectangle 18"
                                                BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#141B24}"
                                                Padding="12">
                                            <VerticalStackLayout Spacing="4">
                                                <Label Text="{Binding Workout.Name}" FontAttributes="Bold" FontSize="16" />

                                                <StackLayout IsVisible="{Binding Workout.Type, Converter={StaticResource IsWeightLiftingConverter}}">
                                                    <Label Text="{Binding Workout.Sets, StringFormat='Sets: {0}'}" FontSize="14" />
                                                    <Label Text="{Binding Workout.Reps, StringFormat='Reps: {0}'}" FontSize="14" />
                                                </StackLayout>

                                                <StackLayout IsVisible="{Binding Workout.Type, Converter={StaticResource IsCardioConverter}}">
                                                    <Label Text="{Binding Workout.Sets, StringFormat='Sessions: {0}'}" FontSize="14" />
                                                    <Label Text="{Binding Workout.Steps, StringFormat='Steps: {0}'}" FontSize="14" />
                                                </StackLayout>

                                                <Label Text="{Binding Workout.MuscleGroup, StringFormat='Muscle Group: {0}'}"
                                                       FontSize="12"
                                                       TextColor="{AppThemeBinding Light=#667384, Dark=#A2B0C2}" />
                                                <Label Text="{Binding Workout.Type, StringFormat='Type: {0}'}"
                                                       FontSize="12"
                                                       TextColor="{AppThemeBinding Light=#667384, Dark=#A2B0C2}" />

                                                <Button Text="Change Day"
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:WorkoutPlanDetailsViewModel}}, Path=ChangeWorkoutDayCommand}"
                                                        CommandParameter="{Binding .}"
                                                        Margin="0,5,0,0"
                                                        BackgroundColor="{AppThemeBinding Light=#E6EFFC, Dark=#1D324B}"
                                                        TextColor="{AppThemeBinding Light=#1D4ED8, Dark=#93C5FD}"
                                                        CornerRadius="12" />
                                            </VerticalStackLayout>
                                        </Border>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
