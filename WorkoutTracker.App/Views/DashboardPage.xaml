<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="WorkoutTracker.Views.DashboardPage"
    x:Name="DashboardPageRoot"
    Title="Profile">

    <Grid>
        <Grid x:Name="DashboardContentHost">
        <ScrollView x:Name="DashboardScrollView">
            <ScrollView.Triggers>
                <DataTrigger TargetType="ScrollView"
                             Binding="{Binding IsCalendarExpanded}"
                             Value="True">
                    <Setter Property="InputTransparent" Value="True" />
                </DataTrigger>
            </ScrollView.Triggers>
            <VerticalStackLayout x:Name="DashboardRootLayout"
                                 Padding="20,18,20,28"
                                 Spacing="16">
            <Border StrokeThickness="0"
                    BackgroundColor="{AppThemeBinding Light=#F4F8FB, Dark=#111A24}"
                    StrokeShape="RoundRectangle 28"
                    Padding="22">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Profile"
                           FontSize="28"
                           FontAttributes="Bold" />
                    <Label Text="Manage your setup, review your training calendar, and check your recent history in one place."
                           FontSize="14"
                           TextColor="{AppThemeBinding Light=#5E6B7B, Dark=#A4B2C5}" />
                </VerticalStackLayout>
            </Border>

            <Grid ColumnDefinitions="*,*"
                  ColumnSpacing="12">
                <Border Grid.Column="0"
                        Stroke="{AppThemeBinding Light=#D6DEE8, Dark=#2A3442}"
                        BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#141B24}"
                        StrokeShape="RoundRectangle 22"
                        Padding="16">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Body Weight"
                               FontAttributes="Bold"
                               FontSize="18" />
                        <Label Text="{Binding BodyWeightSummary}"
                               LineBreakMode="WordWrap" />
                        <Button Text="{Binding BodyWeightButtonText}"
                                Clicked="OnEditBodyWeightClicked"
                                BackgroundColor="{AppThemeBinding Light=#0F766E, Dark=#14B8A6}"
                                TextColor="White" />
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Column="1"
                        Stroke="{AppThemeBinding Light=#D6DEE8, Dark=#2A3442}"
                        BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#141B24}"
                        StrokeShape="RoundRectangle 22"
                        Padding="16">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Theme"
                               FontAttributes="Bold"
                               FontSize="18" />
                        <Label Text="{Binding ThemeLabel}"
                               LineBreakMode="WordWrap" />
                        <Button Text="{Binding ThemeButtonText}"
                                Command="{Binding ToggleThemeCommand}"
                                BackgroundColor="{AppThemeBinding Light=#1F2937, Dark=#334155}"
                                TextColor="White" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <Grid ColumnDefinitions="*,*"
                  ColumnSpacing="12">
                <Border Grid.Column="0"
                        Stroke="{AppThemeBinding Light=#D6E7DD, Dark=#214239}"
                        BackgroundColor="{AppThemeBinding Light=#F3FBF6, Dark=#10211C}"
                        StrokeShape="RoundRectangle 22"
                        Padding="16"
                        IsVisible="{Binding ShowTrainingSnapshot}">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Training Snapshot"
                               FontAttributes="Bold"
                               FontSize="18"
                               TextColor="{AppThemeBinding Light=#1E6B4E, Dark=#84E4C3}" />
                        <Label Text="{Binding TotalWorkoutSessionsSummary}"
                               FontSize="14" />
                        <Label Text="{Binding StrengthWorkoutSessionsSummary}"
                               FontSize="13"
                               TextColor="{AppThemeBinding Light=#5D6A79, Dark=#A6B4C5}" />
                        <Label Text="{Binding CardioWorkoutSessionsSummary}"
                               FontSize="13"
                               TextColor="{AppThemeBinding Light=#5D6A79, Dark=#A6B4C5}" />
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Column="1"
                        Stroke="{AppThemeBinding Light=#D8E0EB, Dark=#2B3544}"
                        BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#141B24}"
                        StrokeShape="RoundRectangle 22"
                        Padding="16">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Plan Status"
                               FontAttributes="Bold"
                               FontSize="18" />
                        <Label Text="{Binding ActivePlanSummary}"
                               FontSize="14"
                               LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <Border Stroke="{AppThemeBinding Light=#D8E0EB, Dark=#2B3544}"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#141B24}"
                    StrokeShape="RoundRectangle 24"
                    Padding="18"
                    IsVisible="{Binding ShowStrengthStatsSection}">
                <VerticalStackLayout Spacing="14">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Strength Stats"
                               FontSize="22"
                               FontAttributes="Bold" />
                        <Label Text="{Binding StrengthStatsSubtitle}"
                               FontSize="13"
                               TextColor="{AppThemeBinding Light=#667384, Dark=#A2B0C2}" />
                    </VerticalStackLayout>

                    <Border StrokeThickness="0"
                            BackgroundColor="{AppThemeBinding Light=#F5F7FA, Dark=#1B2431}"
                            StrokeShape="RoundRectangle 18"
                            Padding="18"
                            IsVisible="{Binding ShowEmptyStrengthStats}">
                        <Label Text="{Binding EmptyStrengthStatsMessage}"
                               HorizontalTextAlignment="Center"
                               TextColor="{AppThemeBinding Light=#6A7686, Dark=#9BABBE}" />
                    </Border>

                    <VerticalStackLayout Spacing="12"
                                         IsVisible="{Binding ShowStrengthStats}">
                        <Grid ColumnDefinitions="*,*"
                              RowDefinitions="Auto,Auto"
                              ColumnSpacing="12"
                              RowSpacing="12">
                            <Border Grid.Row="0"
                                    Grid.Column="0"
                                    Stroke="{AppThemeBinding Light=#E0E7EF, Dark=#334050}"
                                    BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#1A2230}"
                                    StrokeShape="RoundRectangle 18"
                                    Padding="14">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="Top Bench Pattern"
                                           FontAttributes="Bold"
                                           FontSize="14" />
                                    <Label Text="{Binding TopBenchPatternSummary}"
                                           FontSize="18"
                                           FontAttributes="Bold" />
                                </VerticalStackLayout>
                            </Border>

                            <Border Grid.Row="0"
                                    Grid.Column="1"
                                    Stroke="{AppThemeBinding Light=#E0E7EF, Dark=#334050}"
                                    BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#1A2230}"
                                    StrokeShape="RoundRectangle 18"
                                    Padding="14">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="Top Squat Pattern"
                                           FontAttributes="Bold"
                                           FontSize="14" />
                                    <Label Text="{Binding TopSquatPatternSummary}"
                                           FontSize="18"
                                           FontAttributes="Bold" />
                                </VerticalStackLayout>
                            </Border>

                            <Border Grid.Row="1"
                                    Grid.Column="0"
                                    Stroke="{AppThemeBinding Light=#E0E7EF, Dark=#334050}"
                                    BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#1A2230}"
                                    StrokeShape="RoundRectangle 18"
                                    Padding="14">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="Top Deadlift Pattern"
                                           FontAttributes="Bold"
                                           FontSize="14" />
                                    <Label Text="{Binding TopDeadliftPatternSummary}"
                                           FontSize="18"
                                           FontAttributes="Bold" />
                                </VerticalStackLayout>
                            </Border>

                            <Border Grid.Row="1"
                                    Grid.Column="1"
                                    Stroke="{AppThemeBinding Light=#E0E7EF, Dark=#334050}"
                                    BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#1A2230}"
                                    StrokeShape="RoundRectangle 18"
                                    Padding="14">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="Top Pull Pattern"
                                           FontAttributes="Bold"
                                           FontSize="14" />
                                    <Label Text="{Binding TopPullPatternSummary}"
                                           FontSize="18"
                                           FontAttributes="Bold" />
                                </VerticalStackLayout>
                            </Border>
                        </Grid>

                        <Label Text="{Binding BiggestLiftSummary}"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#0F766E, Dark=#7DE6D7}" />
                        <Label Text="{Binding LifetimeStrengthVolumeSummary}"
                               FontSize="13"
                               TextColor="{AppThemeBinding Light=#5D6A79, Dark=#A6B4C5}" />
                        <Label Text="{Binding FavoriteTrainingDaySummary}"
                               FontSize="13"
                               TextColor="{AppThemeBinding Light=#5D6A79, Dark=#A6B4C5}" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <Border Stroke="{AppThemeBinding Light=#D8E0EB, Dark=#2B3544}"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#141B24}"
                    StrokeShape="RoundRectangle 24"
                    Padding="18"
                    IsVisible="{Binding ShowCardioStatsSection}">
                <VerticalStackLayout Spacing="14">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Cardio Stats"
                               FontSize="22"
                               FontAttributes="Bold" />
                        <Label Text="{Binding CardioStatsSubtitle}"
                               FontSize="13"
                               TextColor="{AppThemeBinding Light=#667384, Dark=#A2B0C2}" />
                    </VerticalStackLayout>

                    <Border StrokeThickness="0"
                            BackgroundColor="{AppThemeBinding Light=#F5F7FA, Dark=#1B2431}"
                            StrokeShape="RoundRectangle 18"
                            Padding="18"
                            IsVisible="{Binding ShowEmptyCardioStats}">
                        <Label Text="{Binding EmptyCardioStatsMessage}"
                               HorizontalTextAlignment="Center"
                               TextColor="{AppThemeBinding Light=#6A7686, Dark=#9BABBE}" />
                    </Border>

                    <VerticalStackLayout Spacing="12"
                                         IsVisible="{Binding ShowCardioStats}">
                        <Grid ColumnDefinitions="*,*"
                              RowDefinitions="Auto,Auto"
                              ColumnSpacing="12"
                              RowSpacing="12">
                            <Border Grid.Row="0"
                                    Grid.Column="0"
                                    Stroke="{AppThemeBinding Light=#E0E7EF, Dark=#334050}"
                                    BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#1A2230}"
                                    StrokeShape="RoundRectangle 18"
                                    Padding="14">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="Longest Session"
                                           FontAttributes="Bold"
                                           FontSize="14" />
                                    <Label Text="{Binding LongestCardioSessionSummary}"
                                           FontSize="18"
                                           FontAttributes="Bold" />
                                </VerticalStackLayout>
                            </Border>

                            <Border Grid.Row="0"
                                    Grid.Column="1"
                                    Stroke="{AppThemeBinding Light=#E0E7EF, Dark=#334050}"
                                    BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#1A2230}"
                                    StrokeShape="RoundRectangle 18"
                                    Padding="14">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="Longest Distance"
                                           FontAttributes="Bold"
                                           FontSize="14" />
                                    <Label Text="{Binding LongestCardioDistanceSummary}"
                                           FontSize="18"
                                           FontAttributes="Bold" />
                                </VerticalStackLayout>
                            </Border>

                            <Border Grid.Row="1"
                                    Grid.Column="0"
                                    Stroke="{AppThemeBinding Light=#E0E7EF, Dark=#334050}"
                                    BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#1A2230}"
                                    StrokeShape="RoundRectangle 18"
                                    Padding="14">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="Total Time"
                                           FontAttributes="Bold"
                                           FontSize="14" />
                                    <Label Text="{Binding LifetimeCardioMinutesSummary}"
                                           FontSize="18"
                                           FontAttributes="Bold" />
                                </VerticalStackLayout>
                            </Border>

                            <Border Grid.Row="1"
                                    Grid.Column="1"
                                    Stroke="{AppThemeBinding Light=#E0E7EF, Dark=#334050}"
                                    BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#1A2230}"
                                    StrokeShape="RoundRectangle 18"
                                    Padding="14">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="Total Distance"
                                           FontAttributes="Bold"
                                           FontSize="14" />
                                    <Label Text="{Binding LifetimeCardioDistanceSummary}"
                                           FontSize="18"
                                           FontAttributes="Bold" />
                                </VerticalStackLayout>
                            </Border>
                        </Grid>

                        <Label Text="{Binding FavoriteCardioWorkoutSummary}"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#0F766E, Dark=#7DE6D7}" />
                        <Label Text="{Binding CardioWorkoutSessionsSummary}"
                               FontSize="13"
                               TextColor="{AppThemeBinding Light=#5D6A79, Dark=#A6B4C5}" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <HorizontalStackLayout Spacing="10"
                                   HorizontalOptions="Center"
                                   IsVisible="{Binding ShowStatsToggle}">
                <Button Text=""
                        Command="{Binding ShowStrengthStatsCommand}"
                        WidthRequest="28"
                        HeightRequest="28"
                        MinimumWidthRequest="28"
                        MinimumHeightRequest="28"
                        Padding="0"
                        CornerRadius="14"
                        BorderWidth="0"
                        BackgroundColor="{AppThemeBinding Light=#0F766E, Dark=#14B8A6}"
                        Opacity="0.35">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button"
                                     Binding="{Binding IsStrengthStatsSelected}"
                                     Value="True">
                            <Setter Property="Opacity" Value="1" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>

                <Button Text=""
                        Command="{Binding ShowCardioStatsCommand}"
                        WidthRequest="28"
                        HeightRequest="28"
                        MinimumWidthRequest="28"
                        MinimumHeightRequest="28"
                        Padding="0"
                        CornerRadius="14"
                        BorderWidth="0"
                        BackgroundColor="{AppThemeBinding Light=#1F2937, Dark=#CBD5E1}"
                        Opacity="0.35">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button"
                                     Binding="{Binding IsCardioStatsSelected}"
                                     Value="True">
                            <Setter Property="Opacity" Value="1" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
            </HorizontalStackLayout>

            <Border Stroke="{AppThemeBinding Light=#D8E0EB, Dark=#2B3544}"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#141B24}"
                    StrokeShape="RoundRectangle 24"
                    Padding="18">
                <VerticalStackLayout Spacing="14">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Workout Calendar"
                               FontSize="22"
                               FontAttributes="Bold" />
                        <Label Text="{Binding SelectedDateSummary}"
                               FontSize="13"
                               TextColor="{AppThemeBinding Light=#667384, Dark=#A2B0C2}" />
                        <Label Text="{Binding WorkoutHistorySummary}"
                               FontSize="13"
                               TextColor="{AppThemeBinding Light=#667384, Dark=#A2B0C2}" />
                    </VerticalStackLayout>

                    <Button Text="Open Calendar"
                            Command="{Binding ToggleCalendarVisibilityCommand}"
                            HorizontalOptions="Start"
                            BackgroundColor="{AppThemeBinding Light=#E6FFFA, Dark=#123B36}"
                            TextColor="{AppThemeBinding Light=#0F766E, Dark=#7DE6D7}" />

                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="12">
                        <Border Grid.Column="0"
                                Stroke="{AppThemeBinding Light=#E0E7EF, Dark=#334050}"
                                BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#1A2230}"
                                StrokeShape="RoundRectangle 18"
                                Padding="14"
                                IsVisible="{Binding ShowStrengthDaySummaryCard}">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="Strength Volume"
                                       FontAttributes="Bold"
                                       FontSize="14" />
                                <Label Text="{Binding TotalWeightLifted, StringFormat='{0:N0} lb moved'}"
                                       FontSize="18"
                                       FontAttributes="Bold" />
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Column="1"
                                Stroke="{AppThemeBinding Light=#E0E7EF, Dark=#334050}"
                                BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#1A2230}"
                                StrokeShape="RoundRectangle 18"
                                Padding="14"
                                IsVisible="{Binding ShowCardioDaySummaryCard}">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="Cardio Burn"
                                       FontAttributes="Bold"
                                       FontSize="14" />
                                <Label Text="{Binding CaloriesBurned, StringFormat='{0:N0} kcal'}"
                                       FontSize="18"
                                       FontAttributes="Bold" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Border Stroke="{AppThemeBinding Light=#D8E0EB, Dark=#2B3544}"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#141B24}"
                    StrokeShape="RoundRectangle 24"
                    Padding="18"
                    IsVisible="{Binding HasWorkoutsForSelectedDate}">
                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="Auto,*,Auto"
                          VerticalOptions="Center">
                        <Button Text="Prev"
                                Command="{Binding ShowPreviousWorkoutCommand}"
                                IsEnabled="{Binding CanShowPreviousWorkout}"
                                BackgroundColor="{AppThemeBinding Light=#0F766E, Dark=#14B8A6}"
                                TextColor="White">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button"
                                             Binding="{Binding CanShowPreviousWorkout}"
                                             Value="False">
                                    <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#E5E7EB, Dark=#3F4A5A}" />
                                    <Setter Property="TextColor" Value="{AppThemeBinding Light=#9CA3AF, Dark=#94A3B8}" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>
                        <Label Grid.Column="1"
                               Text="{Binding CurrentWorkoutPositionSummary}"
                               HorizontalTextAlignment="Center"
                               VerticalTextAlignment="Center"
                               FontAttributes="Bold" />
                        <Button Grid.Column="2"
                                Text="Next"
                                Command="{Binding ShowNextWorkoutCommand}"
                                IsEnabled="{Binding CanShowNextWorkout}"
                                BackgroundColor="{AppThemeBinding Light=#0F766E, Dark=#14B8A6}"
                                TextColor="White">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button"
                                             Binding="{Binding CanShowNextWorkout}"
                                             Value="False">
                                    <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#E5E7EB, Dark=#3F4A5A}" />
                                    <Setter Property="TextColor" Value="{AppThemeBinding Light=#9CA3AF, Dark=#94A3B8}" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>
                    </Grid>

                    <Border Padding="12"
                            Stroke="{AppThemeBinding Light=#E0E7EF, Dark=#334050}"
                            BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#1A2230}"
                            StrokeShape="RoundRectangle 18">
                        <VerticalStackLayout Spacing="6"
                                             BindingContext="{Binding CurrentWorkout}">
                            <Label Text="{Binding Name}"
                                   FontAttributes="Bold"
                                   FontSize="16" />
                            <Label Text="{Binding StartTime, StringFormat='Logged at {0:h:mm tt}'}"
                                   FontSize="12"
                                   TextColor="{AppThemeBinding Light=#667384, Dark=#A2B0C2}" />
                            <Label Text="{Binding CaloriesSummary}"
                                   FontSize="12"
                                   TextColor="{AppThemeBinding Light=#667384, Dark=#A2B0C2}"
                                   IsVisible="{Binding HasCalories}" />
                            <Label Text="{Binding MuscleGroup, StringFormat='Focus: {0}'}"
                                   FontSize="13"
                                   TextColor="{AppThemeBinding Light=#0F766E, Dark=#7DE6D7}" />
                            <Label Text="{Binding Sets, StringFormat='Sets: {0}'}"
                                   FontSize="13"
                                   IsVisible="{Binding Type, Converter={StaticResource IsWeightLiftingConverter}}" />
                            <Label Text="{Binding RepDisplay, StringFormat='Reps: {0}'}"
                                   FontSize="13"
                                   IsVisible="{Binding Type, Converter={StaticResource IsWeightLiftingConverter}}" />
                            <Label Text="{Binding Weight, StringFormat='Weight: {0} lbs'}"
                                   FontSize="13"
                                   IsVisible="{Binding Type, Converter={StaticResource IsWeightLiftingConverter}}" />
                            <Label Text="{Binding DurationMinutes, StringFormat='Time: {0} min'}"
                                   FontSize="13"
                                   IsVisible="{Binding HasDuration}" />
                            <Label Text="{Binding DistanceMiles, StringFormat='Distance: {0:F1} mi'}"
                                   FontSize="13"
                                   IsVisible="{Binding HasDistance}" />
                            <Label Text="{Binding Steps, StringFormat='Tracked steps: {0}'}"
                                   FontSize="13"
                                   IsVisible="{Binding HasSteps}" />
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </Border>
            </VerticalStackLayout>
        </ScrollView>
        </Grid>

        <Grid IsVisible="{Binding IsCalendarExpanded}"
              InputTransparent="False"
              BackgroundColor="{AppThemeBinding Light=#0DFFFFFF, Dark=#2210181F}"
              RowDefinitions="*,Auto,*"
              ColumnDefinitions="*,Auto,*"
              ZIndex="10">
            <Button Grid.Row="0"
                    Grid.ColumnSpan="3"
                    Command="{Binding CloseCalendarVisibilityCommand}"
                    BackgroundColor="{AppThemeBinding Light=#26FFFFFF, Dark=#3010181F}"
                    BorderWidth="0"
                    CornerRadius="0"
                    Padding="0" />
            <Button Grid.Row="1"
                    Grid.Column="0"
                    Command="{Binding CloseCalendarVisibilityCommand}"
                    BackgroundColor="{AppThemeBinding Light=#26FFFFFF, Dark=#3010181F}"
                    BorderWidth="0"
                    CornerRadius="0"
                    Padding="0"
                    WidthRequest="20" />
            <Button Grid.Row="1"
                    Grid.Column="2"
                    Command="{Binding CloseCalendarVisibilityCommand}"
                    BackgroundColor="{AppThemeBinding Light=#26FFFFFF, Dark=#3010181F}"
                    BorderWidth="0"
                    CornerRadius="0"
                    Padding="0"
                    WidthRequest="20" />
            <Button Grid.Row="2"
                    Grid.ColumnSpan="3"
                    Command="{Binding CloseCalendarVisibilityCommand}"
                    BackgroundColor="{AppThemeBinding Light=#26FFFFFF, Dark=#3010181F}"
                    BorderWidth="0"
                    CornerRadius="0"
                    Padding="0" />

            <Border Grid.Row="1"
                    Grid.Column="1"
                    Margin="20"
                    StrokeThickness="0"
                    BackgroundColor="{AppThemeBinding Light=#F5FAFF, Dark=#1A2532}"
                    StrokeShape="RoundRectangle 28"
                    Padding="18"
                    WidthRequest="360"
                    MaximumWidthRequest="420"
                    HorizontalOptions="Center"
                    VerticalOptions="Center">
                <Border.Shadow>
                    <Shadow Brush="{AppThemeBinding Light=#330F1720, Dark=Transparent}"
                            Offset="0,8"
                            Radius="26"
                            Opacity="{AppThemeBinding Light=1, Dark=0}" />
                </Border.Shadow>
                <Grid RowDefinitions="Auto"
                      InputTransparent="True">
                    <Border StrokeThickness="0"
                            BackgroundColor="{AppThemeBinding Light=#80FFFFFF, Dark=#22FFFFFF}"
                            StrokeShape="RoundRectangle 28"
                            Margin="1" />
                </Grid>
                <VerticalStackLayout Spacing="12">
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="12">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="Workout Calendar"
                                       FontSize="22"
                                       FontAttributes="Bold" />
                                <Label Text="{Binding SelectedDateSummary}"
                                       FontSize="13"
                                       TextColor="{AppThemeBinding Light=#667384, Dark=#A2B0C2}" />
                            </VerticalStackLayout>
                            <Button Grid.Column="1"
                                    Text="X"
                                    Command="{Binding CloseCalendarVisibilityCommand}"
                                    WidthRequest="40"
                                    HeightRequest="40"
                                    Padding="0"
                                    CornerRadius="20"
                                    BackgroundColor="{AppThemeBinding Light=#E5E7EB, Dark=#334155}"
                                    TextColor="{AppThemeBinding Light=#1F2937, Dark=#F8FAFC}" />
                        </Grid>

                        <Grid ColumnDefinitions="Auto,*,Auto"
                              VerticalOptions="Center">
                            <Button Text="&lt;"
                                    Command="{Binding ShowPreviousMonthCommand}"
                                    BackgroundColor="{AppThemeBinding Light=#E6FFFA, Dark=#123B36}"
                                    TextColor="{AppThemeBinding Light=#0F766E, Dark=#7DE6D7}"
                                    FontSize="18"
                                    FontAttributes="Bold" />
                            <Label Grid.Column="1"
                                   Text="{Binding CurrentCalendarMonthLabel}"
                                   HorizontalTextAlignment="Center"
                                   VerticalTextAlignment="Center"
                                   FontAttributes="Bold"
                                   FontSize="16" />
                            <Button Grid.Column="2"
                                    Text="&gt;"
                                    Command="{Binding ShowNextMonthCommand}"
                                    BackgroundColor="{AppThemeBinding Light=#E6FFFA, Dark=#123B36}"
                                    TextColor="{AppThemeBinding Light=#0F766E, Dark=#7DE6D7}"
                                    FontSize="18"
                                    FontAttributes="Bold" />
                        </Grid>

                        <Grid ColumnDefinitions="*,*,*,*,*,*,*"
                              ColumnSpacing="8">
                            <Label Text="Sun" HorizontalTextAlignment="Center" FontAttributes="Bold" FontSize="12" TextColor="{AppThemeBinding Light=#667384, Dark=#A2B0C2}" />
                            <Label Grid.Column="1" Text="Mon" HorizontalTextAlignment="Center" FontAttributes="Bold" FontSize="12" TextColor="{AppThemeBinding Light=#667384, Dark=#A2B0C2}" />
                            <Label Grid.Column="2" Text="Tue" HorizontalTextAlignment="Center" FontAttributes="Bold" FontSize="12" TextColor="{AppThemeBinding Light=#667384, Dark=#A2B0C2}" />
                            <Label Grid.Column="3" Text="Wed" HorizontalTextAlignment="Center" FontAttributes="Bold" FontSize="12" TextColor="{AppThemeBinding Light=#667384, Dark=#A2B0C2}" />
                            <Label Grid.Column="4" Text="Thu" HorizontalTextAlignment="Center" FontAttributes="Bold" FontSize="12" TextColor="{AppThemeBinding Light=#667384, Dark=#A2B0C2}" />
                            <Label Grid.Column="5" Text="Fri" HorizontalTextAlignment="Center" FontAttributes="Bold" FontSize="12" TextColor="{AppThemeBinding Light=#667384, Dark=#A2B0C2}" />
                            <Label Grid.Column="6" Text="Sat" HorizontalTextAlignment="Center" FontAttributes="Bold" FontSize="12" TextColor="{AppThemeBinding Light=#667384, Dark=#A2B0C2}" />
                        </Grid>

                        <CollectionView x:Name="DashboardCalendarView"
                                        ItemsSource="{Binding CalendarDays}"
                                        SelectionMode="Single"
                                        SelectionChanged="OnCalendarSelectionChanged"
                                        ItemSizingStrategy="MeasureFirstItem"
                                        HeightRequest="312">
                            <CollectionView.ItemsLayout>
                                <GridItemsLayout Orientation="Vertical"
                                                 Span="7"
                                                 VerticalItemSpacing="8"
                                                 HorizontalItemSpacing="8" />
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border Stroke="{Binding BorderColor}"
                                            BackgroundColor="{Binding BackgroundColor}"
                                            StrokeShape="RoundRectangle 14"
                                            StrokeThickness="1"
                                            HeightRequest="44"
                                            Padding="0">
                                        <Grid RowDefinitions="*,Auto"
                                              Padding="0,6,0,6"
                                              InputTransparent="True">
                                            <Label Text="{Binding DayNumberText}"
                                                   TextColor="{Binding TextColor}"
                                                   FontAttributes="{Binding DayFontAttributes}"
                                                   HorizontalTextAlignment="Center"
                                                   VerticalTextAlignment="Center" />
                                            <BoxView Grid.Row="1"
                                                     HeightRequest="6"
                                                     WidthRequest="6"
                                                     CornerRadius="3"
                                                     HorizontalOptions="Center"
                                                     Color="{Binding WorkoutDotColor}"
                                                     IsVisible="{Binding HasWorkout}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>
</ContentPage>

