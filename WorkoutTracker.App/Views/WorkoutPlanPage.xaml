<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:WorkoutTracker.ViewModels"
             x:Class="WorkoutTracker.Views.WorkoutPlanPage"
             Title="Workout Plans">

    <ScrollView>
        <VerticalStackLayout Padding="20,18,20,28" Spacing="18">

            <Border Stroke="{AppThemeBinding Light=#B9D8CC, Dark=#214239}"
                    StrokeThickness="1.5"
                    StrokeShape="RoundRectangle 22"
                    BackgroundColor="{AppThemeBinding Light=#F2FBF7, Dark=#10211C}"
                    Padding="18"
                    Margin="0,0,0,6"
                    IsVisible="{Binding HasActivePlan}">
                <VerticalStackLayout Spacing="6">
                    <Label Text="Current Active Plan"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#155E52, Dark=#84E4C3}" />
                    <Label Text="{Binding CurrentPlan.Name}"
                           FontSize="18"
                           FontAttributes="Bold" />
                    <Label Text="{Binding CurrentPlan.DurationDisplay}"
                           FontSize="13"
                           TextColor="{AppThemeBinding Light=#0F766E, Dark=#7DE6D7}" />
                    <Label Text="{Binding CurrentPlan.Description}"
                           FontSize="14"
                           TextColor="{AppThemeBinding Light=#667384, Dark=#A2B0C2}" />
                    <Label Text="{Binding CurrentPlanTimelineSummary}"
                           FontSize="12"
                           TextColor="{AppThemeBinding Light=#667384, Dark=#A2B0C2}" />
                    <Button Text="View Plan"
                            Command="{Binding SelectWorkoutPlanCommand}"
                            CommandParameter="{Binding CurrentPlan}"
                            Margin="0,10,0,0"
                            BackgroundColor="{AppThemeBinding Light=#E7F6F4, Dark=#143936}"
                            TextColor="{AppThemeBinding Light=#0F766E, Dark=#7DE6D7}"
                            CornerRadius="12" />
                </VerticalStackLayout>
            </Border>

            <Label Text="Available Workout Plans"
                   FontSize="26"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />

            <VerticalStackLayout Spacing="8">
                <Label Text="Choose a category"
                       FontAttributes="Bold" />
                <Picker Title="Select a workout category"
                        ItemsSource="{Binding AvailableCategories}"
                        SelectedItem="{Binding SelectedCategory}" />
            </VerticalStackLayout>

            <CollectionView ItemsSource="{Binding GroupedWorkoutPlans}"
                            IsVisible="{Binding ShowGroupedWorkoutPlans}"
                            SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <VerticalStackLayout Spacing="10">
                            <Label Text="{Binding CategoryName}"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#155E52, Dark=#8EE7D2}" />

                            <CollectionView ItemsSource="{Binding .}"
                                            SelectionMode="None">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Stroke="{AppThemeBinding Light=#D8E0EB, Dark=#2B3544}"
                                                StrokeThickness="1"
                                                StrokeShape="RoundRectangle 18"
                                                BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#141B24}"
                                                Padding="15"
                                                Margin="0,0,0,10">
                                            <VerticalStackLayout Spacing="4">
                                                <Label Text="{Binding Name}" FontSize="18" FontAttributes="Bold" />
                                                <Label Text="{Binding DurationDisplay, StringFormat='Duration: {0}'}"
                                                       FontSize="13"
                                                       TextColor="{AppThemeBinding Light=#0F766E, Dark=#7DE6D7}" />
                                                <Label Text="{Binding Description}"
                                                       FontSize="14"
                                                       TextColor="{AppThemeBinding Light=#667384, Dark=#A2B0C2}"
                                                       Margin="0,5,0,0" />
                                                <Label Text="Custom plan"
                                                       FontSize="12"
                                                       TextColor="{AppThemeBinding Light=#7B8797, Dark=#95A3B8}"
                                                       IsVisible="{Binding IsCustom}" />
                                                <Button Text="View Plan"
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:WorkoutPlanViewModel}}, Path=SelectWorkoutPlanCommand}"
                                                        CommandParameter="{Binding .}"
                                                        Margin="0,10,0,0" />
                                            </VerticalStackLayout>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <CollectionView ItemsSource="{Binding WorkoutPlans}"
                            IsVisible="{Binding ShowFlatWorkoutPlans}"
                            SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Stroke="{AppThemeBinding Light=#D8E0EB, Dark=#2B3544}"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 18"
                                BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#141B24}"
                                Padding="15"
                                Margin="0,0,0,10">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding Name}" FontSize="18" FontAttributes="Bold" />
                                <Label Text="{Binding Category, StringFormat='Category: {0}'}"
                                       FontSize="13"
                                       TextColor="{AppThemeBinding Light=#4C6B65, Dark=#9CCFC3}" />
                                <Label Text="{Binding DurationDisplay, StringFormat='Duration: {0}'}"
                                       FontSize="13"
                                       TextColor="{AppThemeBinding Light=#0F766E, Dark=#7DE6D7}" />
                                <Label Text="{Binding Description}"
                                       FontSize="14"
                                       TextColor="{AppThemeBinding Light=#667384, Dark=#A2B0C2}"
                                       Margin="0,5,0,0" />
                                <Label Text="Custom plan"
                                       FontSize="12"
                                       TextColor="{AppThemeBinding Light=#7B8797, Dark=#95A3B8}"
                                       IsVisible="{Binding IsCustom}" />
                                <Button Text="View Plan"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:WorkoutPlanViewModel}}, Path=SelectWorkoutPlanCommand}"
                                        CommandParameter="{Binding .}"
                                        Margin="0,10,0,0" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Button Text="{Binding CreatePlanButtonText}"
                    Command="{Binding ToggleCreatePlanCommand}"
                    BackgroundColor="{AppThemeBinding Light=#0F766E, Dark=#14B8A6}"
                    TextColor="White"
                    CornerRadius="12" />

            <VerticalStackLayout IsVisible="{Binding IsCreatePlanVisible}"
                                 Spacing="10">
                <BoxView HeightRequest="1"
                         BackgroundColor="{AppThemeBinding Light=#D7E0EA, Dark=#334155}"
                         Margin="0,10,0,10" />

                <Label Text="Create Your Own Plan"
                       FontSize="20"
                       FontAttributes="Bold"
                       HorizontalOptions="Center" />

                <Entry Placeholder="Plan Name"
                       Text="{Binding NewPlanName}"
                       Margin="0,5,0,0" />

                <Picker Title="Category"
                        ItemsSource="{Binding AvailableNewPlanCategories}"
                        SelectedItem="{Binding SelectedNewPlanCategory}"
                        Margin="0,5,0,0" />

                <Entry Placeholder="Duration in weeks"
                       Keyboard="Numeric"
                       Text="{Binding NewPlanDurationInWeeks}"
                       Margin="0,5,0,0" />

                <Editor Placeholder="Plan Description"
                        Text="{Binding NewPlanDescription}"
                        AutoSize="TextChanges"
                        HeightRequest="100"
                        Margin="0,5,0,0" />

                <Button Text="Add Plan"
                        Command="{Binding AddWorkoutPlanCommand}"
                        Margin="0,10,0,0"
                        BackgroundColor="{AppThemeBinding Light=#0F766E, Dark=#14B8A6}"
                        TextColor="White"
                        CornerRadius="12" />
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
