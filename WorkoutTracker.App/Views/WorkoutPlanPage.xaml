<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:WorkoutTracker.ViewModels"
             x:Class="WorkoutTracker.Views.WorkoutPlanPage"
             Title="Workout Plans">

    <ScrollView x:Name="PlanScrollView">
        <VerticalStackLayout Padding="20,18,20,28" Spacing="18">

            <Border Stroke="{AppThemeBinding Light=#B9D8CC, Dark=#214239}"
                    StrokeThickness="1.5"
                    StrokeShape="RoundRectangle 22"
                    BackgroundColor="{AppThemeBinding Light=#F2FBF7, Dark=#10211C}"
                    Padding="18"
                    Margin="0,0,0,6"
                    IsVisible="{Binding HasActivePlan}">
                <VerticalStackLayout Spacing="6">
                    <Label Text="Current Active Plan"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#155E52, Dark=#84E4C3}" />
                    <Label Text="{Binding CurrentPlan.Name}"
                           FontSize="18"
                           FontAttributes="Bold" />
                    <Label Text="{Binding CurrentPlan.DurationDisplay}"
                           FontSize="13"
                           TextColor="{AppThemeBinding Light=#0F766E, Dark=#7DE6D7}" />
                    <Label Text="{Binding CurrentPlan.Description}"
                           FontSize="14"
                           TextColor="{AppThemeBinding Light=#667384, Dark=#A2B0C2}" />
                    <Label Text="{Binding CurrentPlanTimelineSummary}"
                           FontSize="12"
                           TextColor="{AppThemeBinding Light=#667384, Dark=#A2B0C2}" />
                    <Button Text="Weekly Schedule"
                            Command="{Binding OpenWeeklyScheduleCommand}"
                            Margin="0,10,0,0"
                            BackgroundColor="{AppThemeBinding Light=#E7F6F4, Dark=#143936}"
                            TextColor="White"
                            CornerRadius="12" />
                </VerticalStackLayout>
            </Border>

            <Label Text="Available Workout Plans"
                   FontSize="26"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />

            <Border Stroke="{AppThemeBinding Light=#0B5F59, Dark=#2DD4BF}"
                    StrokeThickness="1.5"
                    StrokeShape="RoundRectangle 18"
                    BackgroundColor="{AppThemeBinding Light=#0F766E, Dark=#115E59}"
                    Padding="16">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Browse Existing Plans"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="White" />
                    <Label Text="Pick a category to load ready-made workout plans."
                           FontSize="13"
                           TextColor="{AppThemeBinding Light=#D8FFFA, Dark=#CCFBF1}" />
                    <Border StrokeThickness="0"
                            BackgroundColor="White"
                            StrokeShape="RoundRectangle 12"
                            Padding="12,10">
                        <Grid>
                            <Picker Title=""
                                    TitleColor="#0F172A"
                                    TextColor="#0F172A"
                                    BackgroundColor="White"
                                    ItemsSource="{Binding AvailableCategories}"
                                    SelectedItem="{Binding SelectedCategory}" />
                            <Label Text="Select a workout category"
                                   InputTransparent="True"
                                   VerticalOptions="Center"
                                   Margin="4,0,28,0"
                                   TextColor="#0F172A"
                                   IsVisible="{Binding ShowCategoryPrompt}" />
                        </Grid>
                    </Border>
                </VerticalStackLayout>
            </Border>

            <Border IsVisible="{Binding ShowCategoryPrompt}"
                    Stroke="{AppThemeBinding Light=#D8E0EB, Dark=#2B3544}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 18"
                    BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#101720}"
                    Padding="16">
                <Label Text="Pick All Categories to show everything, or choose one category to browse just that section."
                       FontSize="14"
                       HorizontalTextAlignment="Center"
                       TextColor="{AppThemeBinding Light=#667384, Dark=#A2B0C2}" />
            </Border>

            <VerticalStackLayout IsVisible="{Binding ShowGroupedWorkoutPlans}"
                                 Spacing="14"
                                 BindableLayout.ItemsSource="{Binding GroupedWorkoutPlans}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate>
                        <VerticalStackLayout Spacing="10">
                            <Label Text="{Binding CategoryName}"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#155E52, Dark=#8EE7D2}" />

                            <VerticalStackLayout Spacing="10"
                                                 BindableLayout.ItemsSource="{Binding .}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate>
                                        <Border Stroke="{AppThemeBinding Light=#D8E0EB, Dark=#2B3544}"
                                                StrokeThickness="1"
                                                StrokeShape="RoundRectangle 18"
                                                BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#141B24}"
                                                Padding="15">
                                            <VerticalStackLayout Spacing="4">
                                                <Label Text="{Binding Name}" FontSize="18" FontAttributes="Bold" />
                                                <Label Text="{Binding DurationDisplay, StringFormat='Duration: {0}'}"
                                                       FontSize="13"
                                                       TextColor="{AppThemeBinding Light=#0F766E, Dark=#7DE6D7}" />
                                                <Label Text="{Binding Description}"
                                                       FontSize="14"
                                                       TextColor="{AppThemeBinding Light=#667384, Dark=#A2B0C2}"
                                                       Margin="0,5,0,0" />
                                                <Label Text="Custom plan"
                                                       FontSize="12"
                                                       TextColor="{AppThemeBinding Light=#7B8797, Dark=#95A3B8}"
                                                       IsVisible="{Binding IsCustom}" />
                                                <Button Text="View Plan"
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:WorkoutPlanViewModel}}, Path=SelectWorkoutPlanCommand}"
                                                        CommandParameter="{Binding .}"
                                                        Margin="0,10,0,0"
                                                        TextColor="White" />
                                            </VerticalStackLayout>
                                        </Border>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>

            <VerticalStackLayout IsVisible="{Binding ShowFlatWorkoutPlans}"
                                 Spacing="10"
                                 BindableLayout.ItemsSource="{Binding WorkoutPlans}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate>
                        <Border Stroke="{AppThemeBinding Light=#D8E0EB, Dark=#2B3544}"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 18"
                                BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#141B24}"
                                Padding="15">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding Name}" FontSize="18" FontAttributes="Bold" />
                                <Label Text="{Binding Category, StringFormat='Category: {0}'}"
                                       FontSize="13"
                                       TextColor="{AppThemeBinding Light=#4C6B65, Dark=#9CCFC3}" />
                                <Label Text="{Binding DurationDisplay, StringFormat='Duration: {0}'}"
                                       FontSize="13"
                                       TextColor="{AppThemeBinding Light=#0F766E, Dark=#7DE6D7}" />
                                <Label Text="{Binding Description}"
                                       FontSize="14"
                                       TextColor="{AppThemeBinding Light=#667384, Dark=#A2B0C2}"
                                       Margin="0,5,0,0" />
                                <Label Text="Custom plan"
                                       FontSize="12"
                                       TextColor="{AppThemeBinding Light=#7B8797, Dark=#95A3B8}"
                                       IsVisible="{Binding IsCustom}" />
                                <Button Text="View Plan"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:WorkoutPlanViewModel}}, Path=SelectWorkoutPlanCommand}"
                                        CommandParameter="{Binding .}"
                                        Margin="0,10,0,0"
                                        TextColor="White" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>

            <Button Text="{Binding CreatePlanButtonText}"
                    Command="{Binding ToggleCreatePlanCommand}"
                    BackgroundColor="{AppThemeBinding Light=#0F766E, Dark=#14B8A6}"
                    TextColor="White"
                    CornerRadius="12" />

            <VerticalStackLayout x:Name="CreatePlanSection"
                                 IsVisible="{Binding IsCreatePlanVisible}"
                                 Spacing="10">
                <BoxView HeightRequest="1"
                         BackgroundColor="{AppThemeBinding Light=#D7E0EA, Dark=#334155}"
                         Margin="0,10,0,10" />

                <Label Text="Create Your Own Plan"
                       FontSize="20"
                       FontAttributes="Bold"
                       HorizontalOptions="Center" />

                <Border Stroke="{AppThemeBinding Light=#D8E0EB, Dark=#2B3544}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 18"
                        BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#101720}"
                        Padding="14">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Plan Preview"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#155E52, Dark=#8EE7D2}" />
                        <Label Text="{Binding NewPlanNameSummary}"
                               FontSize="14" />
                        <Label Text="{Binding NewPlanDurationSummary}"
                               FontSize="14"
                               TextColor="{AppThemeBinding Light=#0F766E, Dark=#7DE6D7}" />
                        <Label Text="{Binding NewPlanCategorySummary}"
                               FontSize="13"
                               TextColor="{AppThemeBinding Light=#667384, Dark=#A2B0C2}" />
                    </VerticalStackLayout>
                </Border>

                <Entry x:Name="PlanNameEntry"
                       Placeholder="Plan Name"
                       Text="{Binding NewPlanName}"
                       Margin="0,5,0,0" />

                <Picker Title="Category"
                        ItemsSource="{Binding AvailableNewPlanCategories}"
                        SelectedItem="{Binding SelectedNewPlanCategory}"
                        Margin="0,5,0,0" />

                <Entry Placeholder="Duration in weeks"
                       Keyboard="Numeric"
                       Text="{Binding NewPlanDurationInWeeks}"
                       Margin="0,5,0,0" />

                <Editor Placeholder="Plan Description"
                        Text="{Binding NewPlanDescription}"
                        AutoSize="TextChanges"
                        HeightRequest="100"
                        Margin="0,5,0,0" />

                <Button Text="Add Plan"
                        Command="{Binding AddWorkoutPlanCommand}"
                        Margin="0,10,0,0"
                        BackgroundColor="{AppThemeBinding Light=#0F766E, Dark=#14B8A6}"
                        TextColor="White"
                        CornerRadius="12" />
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
