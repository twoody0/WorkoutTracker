<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:WorkoutTracker.ViewModels"
             x:Class="WorkoutTracker.Views.AddWorkoutPage"
             Title="Add Workout">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">
            <Label Text="Create New Workout" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" />
            <Label Text="{Binding Day, StringFormat='Scheduling for {0}'}"
                   FontSize="16"
                   HorizontalOptions="Center"
                   TextColor="Gray" />

            <Border Stroke="{AppThemeBinding Light=#D9E5D2, Dark=#214239}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 12"
                    BackgroundColor="{AppThemeBinding Light=#F7FBF4, Dark=#10211C}"
                    Padding="14">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Workout Plan Suggestions"
                           FontAttributes="Bold"
                           FontSize="18"
                           TextColor="{AppThemeBinding Light=#0F172A, Dark=#CCFBF1}" />
                    <Label Text="{Binding RecommendedWorkoutSummary}"
                           TextColor="{AppThemeBinding Light=#4F5B4B, Dark=#9FD7C8}" />

                    <CollectionView ItemsSource="{Binding RecommendedWorkouts}"
                                    IsVisible="{Binding HasRecommendedWorkouts}"
                                    SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Stroke="{AppThemeBinding Light=#C7D8BF, Dark=#334155}"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 10"
                                        BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#141B24}"
                                        Padding="10"
                                        Margin="0,0,0,8">
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border"
                                                     Binding="{Binding IsSelected}"
                                                     Value="True">
                                            <Setter Property="Stroke" Value="{AppThemeBinding Light=#0F766E, Dark=#14B8A6}" />
                                            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#F0FDFA, Dark=#10211C}" />
                                        </DataTrigger>
                                    </Border.Triggers>
                                    <VerticalStackLayout Spacing="6">
                                        <Label Text="{Binding Name}" FontAttributes="Bold" />
                                        <Label Text="{Binding MuscleGroup, StringFormat='Focus: {0}'}"
                                               FontSize="12"
                                               TextColor="Gray"
                                               IsVisible="{Binding ShowDetails}" />
                                        <Label Text="{Binding Sets, StringFormat='Sets: {0}'}"
                                               FontSize="12"
                                               TextColor="Gray"
                                               IsVisible="{Binding ShowWeightLiftingDetails}" />
                                        <Label Text="{Binding Reps, StringFormat='Reps: {0}'}"
                                               FontSize="12"
                                               TextColor="Gray"
                                               IsVisible="{Binding ShowWeightLiftingDetails}" />
                                         <Label Text="{Binding DurationMinutes, StringFormat='Time: {0} min'}"
                                                FontSize="12"
                                                TextColor="Gray"
                                                IsVisible="{Binding HasDuration}" />
                                         <Label Text="{Binding DistanceMiles, StringFormat='Distance: {0:F1} mi'}"
                                                FontSize="12"
                                                TextColor="Gray"
                                                IsVisible="{Binding HasDistance}" />
                                         <Label Text="{Binding Steps, StringFormat='Tracked steps: {0}'}"
                                                FontSize="12"
                                                TextColor="Gray"
                                                IsVisible="{Binding HasSteps}" />
                                        <Button Text="Use This Workout"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:AddWorkoutViewModel}}, Path=UseRecommendedWorkoutCommand}"
                                                CommandParameter="{Binding .}"
                                                BackgroundColor="{AppThemeBinding Light=#0F766E, Dark=#14B8A6}"
                                                TextColor="White"
                                                CornerRadius="8"
                                                IsVisible="{Binding ShowUseButton}" />
                                        <Label Text="{Binding SelectedText}"
                                               FontSize="12"
                                               FontAttributes="Bold"
                                               TextColor="{AppThemeBinding Light=#0F766E, Dark=#7DE6D7}"
                                               IsVisible="{Binding ShowSelectedState}" />
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

            <Border Stroke="{AppThemeBinding Light=#D8E0EB, Dark=#2B3544}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 18"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#141B24}"
                    Padding="16">
                <VerticalStackLayout Spacing="14">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Workout Type"
                               FontAttributes="Bold"
                               FontSize="14" />
                        <Picker Title="Choose a workout type"
                                ItemsSource="{Binding WorkoutTypes}"
                                SelectedItem="{Binding SelectedType}" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="Muscle Group"
                               FontAttributes="Bold"
                               FontSize="14" />
                        <Picker Title="Choose a muscle group"
                                ItemsSource="{Binding MuscleGroups}"
                                SelectedItem="{Binding SelectedMuscleGroup}" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="Workout Name"
                               FontAttributes="Bold"
                               FontSize="14" />
                        <Entry Placeholder="Start typing an exercise name"
                               Text="{Binding Name}" />
                        <Label Text="If this exercise is in the library, tap it below to fill the name quickly."
                               FontSize="12"
                               TextColor="{AppThemeBinding Light=#667384, Dark=#A2B0C2}"
                               IsVisible="{Binding IsWeightLifting}" />
                    </VerticalStackLayout>

                    <Border IsVisible="{Binding HasExerciseSuggestions}"
                            Stroke="{AppThemeBinding Light=#D8E0EB, Dark=#2B3544}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 16"
                            BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#101720}"
                            Padding="12">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="Library Matches"
                                   FontAttributes="Bold"
                                   FontSize="15"
                                   TextColor="{AppThemeBinding Light=#155E52, Dark=#8EE7D2}" />
                            <CollectionView ItemsSource="{Binding ExerciseSuggestions}"
                                            SelectionMode="None"
                                            HeightRequest="220">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Stroke="{AppThemeBinding Light=#D8E0EB, Dark=#334050}"
                                                StrokeThickness="1"
                                                StrokeShape="RoundRectangle 14"
                                                BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#141B24}"
                                                Padding="10"
                                                Margin="0,0,0,8">
                                            <Grid ColumnDefinitions="*,Auto"
                                                  ColumnSpacing="10">
                                                <VerticalStackLayout Spacing="2">
                                                    <Label Text="{Binding Name}"
                                                           FontAttributes="Bold" />
                                                    <Label Text="{Binding MuscleGroup, StringFormat='Focus: {0}'}"
                                                           FontSize="12"
                                                           TextColor="{AppThemeBinding Light=#667384, Dark=#A2B0C2}" />
                                                </VerticalStackLayout>
                                                <Button Grid.Column="1"
                                                        Text="Use"
                                                        Padding="12,6"
                                                        VerticalOptions="Center"
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:AddWorkoutViewModel}}, Path=SelectExerciseSuggestionCommand}"
                                                        CommandParameter="{Binding .}"
                                                        BackgroundColor="{AppThemeBinding Light=#E7F6F4, Dark=#143936}"
                                                        TextColor="{AppThemeBinding Light=#0F766E, Dark=#7DE6D7}"
                                                        CornerRadius="12" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                    </Border>

                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="12"
                          IsVisible="{Binding IsWeightLifting}">
                        <VerticalStackLayout Grid.Column="0"
                                             Spacing="6">
                            <Label Text="Sets"
                                   FontAttributes="Bold"
                                   FontSize="14" />
                            <Entry Placeholder="Sets: 3"
                                   Text="{Binding Sets}"
                                   Keyboard="Numeric" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1"
                                             Spacing="6">
                            <Label Text="Reps"
                                   FontAttributes="Bold"
                                   FontSize="14" />
                            <Entry Placeholder="Reps: 10"
                                   Text="{Binding Reps}"
                                   Keyboard="Numeric" />
                        </VerticalStackLayout>
                    </Grid>

                     <VerticalStackLayout Spacing="6"
                                          IsVisible="{Binding IsCardio}">
                        <Label Text="Duration (minutes)"
                                FontAttributes="Bold"
                                FontSize="14" />
                        <Entry Placeholder="Duration: 30"
                               Text="{Binding DurationMinutes}"
                               Keyboard="Numeric" />
                        <Label Text="Distance (miles)"
                               FontAttributes="Bold"
                               FontSize="14" />
                        <Entry Placeholder="Distance: 2.5"
                               Text="{Binding DistanceMiles}"
                               Keyboard="Numeric" />
                        <Label Text="Tracked steps (optional)"
                               FontAttributes="Bold"
                               FontSize="14" />
                        <Entry Placeholder="Only if tracked by watch or phone"
                               Text="{Binding Steps}"
                               Keyboard="Numeric" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <Button Text="Save Workout"
                    Command="{Binding SaveCommand}"
                    BackgroundColor="{AppThemeBinding Light=#0F766E, Dark=#14B8A6}"
                    TextColor="White"
                    CornerRadius="8" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
