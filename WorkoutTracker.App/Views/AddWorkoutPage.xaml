<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:WorkoutTracker.ViewModels"
             x:Class="WorkoutTracker.Views.AddWorkoutPage"
             Title="Add Workout">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">
            <Label Text="Create New Workout" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" />
            <Label Text="{Binding Day, StringFormat='Scheduling for {0}'}"
                   FontSize="16"
                   HorizontalOptions="Center"
                   TextColor="Gray" />

            <Border Stroke="#D9E5D2"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 12"
                    BackgroundColor="#F7FBF4"
                    Padding="14">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Workout Plan Suggestions"
                           FontAttributes="Bold"
                           FontSize="18" />
                    <Label Text="{Binding RecommendedWorkoutSummary}"
                           TextColor="#4F5B4B" />

                    <CollectionView ItemsSource="{Binding RecommendedWorkouts}"
                                    IsVisible="{Binding HasRecommendedWorkouts}"
                                    SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Stroke="{AppThemeBinding Light=#C7D8BF, Dark=#334155}"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 10"
                                        BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#141B24}"
                                        Padding="10"
                                        Margin="0,0,0,8">
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border"
                                                     Binding="{Binding IsSelected}"
                                                     Value="True">
                                            <Setter Property="Stroke" Value="{AppThemeBinding Light=#0F766E, Dark=#14B8A6}" />
                                            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#F0FDFA, Dark=#10211C}" />
                                        </DataTrigger>
                                    </Border.Triggers>
                                    <VerticalStackLayout Spacing="6">
                                        <Label Text="{Binding Name}" FontAttributes="Bold" />
                                        <Label Text="{Binding MuscleGroup, StringFormat='Focus: {0}'}"
                                               FontSize="12"
                                               TextColor="Gray"
                                               IsVisible="{Binding ShowDetails}" />
                                        <Label Text="{Binding Sets, StringFormat='Sets: {0}'}"
                                               FontSize="12"
                                               TextColor="Gray"
                                               IsVisible="{Binding ShowWeightLiftingDetails}" />
                                        <Label Text="{Binding Reps, StringFormat='Reps: {0}'}"
                                               FontSize="12"
                                               TextColor="Gray"
                                               IsVisible="{Binding ShowWeightLiftingDetails}" />
                                        <Label Text="{Binding Steps, StringFormat='Steps: {0}'}"
                                               FontSize="12"
                                               TextColor="Gray"
                                               IsVisible="{Binding ShowCardioDetails}" />
                                        <Button Text="Use This Workout"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:AddWorkoutViewModel}}, Path=UseRecommendedWorkoutCommand}"
                                                CommandParameter="{Binding .}"
                                                BackgroundColor="{AppThemeBinding Light=#0F766E, Dark=#14B8A6}"
                                                TextColor="White"
                                                CornerRadius="8"
                                                IsVisible="{Binding ShowUseButton}" />
                                        <Label Text="{Binding SelectedText}"
                                               FontSize="12"
                                               FontAttributes="Bold"
                                               TextColor="{AppThemeBinding Light=#0F766E, Dark=#7DE6D7}"
                                               IsVisible="{Binding ShowSelectedState}" />
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

            <Entry Placeholder="Workout Name" Text="{Binding Name}" />
            <Entry Placeholder="Muscle Group" Text="{Binding MuscleGroup}" />

            <!-- Workout Type Picker -->
            <Picker Title="Workout Type" ItemsSource="{Binding WorkoutTypes}" SelectedItem="{Binding SelectedType}" />

            <!-- Show Sets/Reps for Weightlifting -->
            <StackLayout IsVisible="{Binding IsWeightLifting}">
                <Entry Placeholder="Sets" Text="{Binding Sets}" Keyboard="Numeric" />
                <Entry Placeholder="Reps" Text="{Binding Reps}" Keyboard="Numeric" />
            </StackLayout>

            <!-- Show Steps for Cardio -->
            <StackLayout IsVisible="{Binding IsCardio}">
                <Entry Placeholder="Steps" Text="{Binding Steps}" Keyboard="Numeric" />
            </StackLayout>

            <!-- Save Button -->
            <Button Text="Save Workout" Command="{Binding SaveCommand}" BackgroundColor="#4CAF50" TextColor="White" CornerRadius="8" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
