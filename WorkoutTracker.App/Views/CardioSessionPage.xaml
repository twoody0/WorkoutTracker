<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:convertors="clr-namespace:WorkoutTracker.Converters"
    x:Class="WorkoutTracker.Views.CardioSessionPage"
    Title="Cardio Session">
    <ContentPage.Resources>
        <ResourceDictionary>
            <convertors:InverseBooleanConverter x:Key="InverseBooleanConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">
            <Label Text="Cardio Session"
                   FontSize="24"
                   HorizontalOptions="Center" />
            <Label Text="Start your session, let the timer run, then stop it when you're done. Steps are captured automatically when your device allows it, and we'll ask for distance at the end if needed."
                    HorizontalTextAlignment="Center"
                    TextColor="Gray" />

            <Border Stroke="{AppThemeBinding Light=#D8E0EB, Dark=#2B3544}"
                    StrokeShape="RoundRectangle 12"
                    Padding="14"
                    IsVisible="{Binding ShowPlannedTargets}">
                <VerticalStackLayout Spacing="6">
                    <Label Text="Planned cardio target"
                           FontAttributes="Bold" />
                    <HorizontalStackLayout Spacing="12">
                        <Label Text="{Binding PlannedDurationText}"
                               IsVisible="{Binding HasPlannedDuration}" />
                        <Label Text="{Binding PlannedDistanceText}"
                               IsVisible="{Binding HasPlannedDistance}" />
                        <Label Text="{Binding PlannedTargetRpeText}"
                               IsVisible="{Binding HasPlannedTargetRpe}" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <Label Text="Session Name"
                   FontAttributes="Bold" />
            <Entry x:Name="SessionNameEntry"
                   Text="{Binding SessionName}"
                   Placeholder="Run, Walk, Bike Ride..."
                   Focused="SessionNameEntry_Focused"
                   Unfocused="SessionNameEntry_Unfocused" />

            <Border Stroke="{AppThemeBinding Light=#D8E0EB, Dark=#2B3544}"
                    StrokeShape="RoundRectangle 14"
                    Padding="6"
                    MaximumHeightRequest="220"
                    IsVisible="{Binding IsSessionNameFocused}">
                <CollectionView ItemsSource="{Binding CardioNameSuggestions}"
                                SelectionMode="Single"
                                SelectionChanged="OnCardioNameSelected">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10,8"
                                    Margin="0,0,0,6"
                                    Stroke="{AppThemeBinding Light=#E5EAF1, Dark=#334155}"
                                    StrokeShape="RoundRectangle 10">
                                <Label Text="{Binding .}" />
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Border>

            <Border Stroke="LightGray"
                    StrokeShape="RoundRectangle 12"
                    Padding="16"
                    IsVisible="{Binding ShowSessionControls}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="{Binding ElapsedTimeDisplay, StringFormat='Elapsed: {0}'}"
                           FontSize="20"
                           HorizontalOptions="Center" />
                    <Label Text="{Binding StepTrackingStatusText}"
                           HorizontalOptions="Center"
                           TextColor="Gray" />
                    <Label Text="{Binding SessionSteps, StringFormat='Tracked steps: {0}'}"
                            HorizontalOptions="Center" />
                    <Label Text="{Binding EstimatedDistanceFromStepsText}"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"
                           FontSize="12"
                           TextColor="Gray" />
                     <Label Text="The timer keeps its place across lock/resume so you can reopen and stop it when you're done."
                            FontSize="12"
                            HorizontalTextAlignment="Center"
                            TextColor="Gray" />
                 </VerticalStackLayout>
             </Border>

             <Button Text="Start"
                     Command="{Binding StartSessionCommand}"
                     IsEnabled="{Binding HasSelectedSessionName}"
                     IsVisible="{Binding IsTracking, Converter={StaticResource InverseBooleanConverter}}" />
            <Button Text="Stop and Save"
                    Command="{Binding StopSessionCommand}"
                    IsVisible="{Binding IsTracking}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
