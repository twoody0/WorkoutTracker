<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:WorkoutTracker.ViewModels"
             x:Class="WorkoutTracker.Views.WeeklySchedulePage"
             Title="Weekly Schedule">

    <ScrollView>
        <VerticalStackLayout Padding="20,18,20,28"
                             Spacing="16">
            <Border Stroke="{AppThemeBinding Light=#D6DEE8, Dark=#2A3442}"
                    BackgroundColor="{AppThemeBinding Light=#F4F8FB, Dark=#111A24}"
                    StrokeShape="RoundRectangle 24"
                    Padding="20">
                <VerticalStackLayout Spacing="6">
                    <Label Text="Your Weekly Schedule"
                           FontSize="28"
                           FontAttributes="Bold" />
                    <Label Text="Review each day, then jump into edit mode when you want to rebalance the plan."
                           FontSize="14"
                           TextColor="{AppThemeBinding Light=#5E6B7B, Dark=#A4B2C5}" />
                </VerticalStackLayout>
            </Border>

            <Border Stroke="{AppThemeBinding Light=#D6E7DD, Dark=#214239}"
                    BackgroundColor="{AppThemeBinding Light=#F3FBF6, Dark=#10211C}"
                    StrokeShape="RoundRectangle 20"
                    Padding="14"
                    IsVisible="{Binding HasActivePlan}">
                <VerticalStackLayout Spacing="4">
                    <Label Text="{Binding ActivePlanName}"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#1E6B4E, Dark=#84E4C3}" />
                    <Label Text="{Binding ActivePlanTimelineSummary}"
                           FontSize="13"
                           TextColor="{AppThemeBinding Light=#5D6A79, Dark=#A6B4C5}" />
                    <Button Text="Preview Future Weeks"
                            Command="{Binding ViewPlanPreviewCommand}"
                            Margin="0,8,0,0"
                            BackgroundColor="{AppThemeBinding Light=#E7F6F4, Dark=#143936}"
                            TextColor="{AppThemeBinding Light=#0F766E, Dark=#7DE6D7}"
                            CornerRadius="12" />
                </VerticalStackLayout>
            </Border>

            <VerticalStackLayout Spacing="14"
                                  BindableLayout.ItemsSource="{Binding WeeklySchedule}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate>
                        <Border Stroke="{AppThemeBinding Light=#D8E0EB, Dark=#2B3544}"
                                BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#141B24}"
                                StrokeShape="RoundRectangle 22"
                                Padding="16">
                            <VerticalStackLayout Spacing="12">
                                <Grid ColumnDefinitions="Auto,*,Auto"
                                      ColumnSpacing="10">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:WeeklyScheduleViewModel}}, Path=ToggleDayCommand}"
                                                              CommandParameter="{Binding .}" />
                                    </Grid.GestureRecognizers>
                                    <Label Text="{Binding ToggleGlyph}"
                                           FontSize="18"
                                           VerticalOptions="Center"
                                           IsVisible="{Binding CanToggle}"
                                           TextColor="{AppThemeBinding Light=#0F766E, Dark=#7DE6D7}" />
                                    <VerticalStackLayout Grid.Column="1" Spacing="2">
                                        <HorizontalStackLayout Spacing="8">
                                            <Label Text="{Binding DayLabel}"
                                                   FontSize="20"
                                                   FontAttributes="Bold" />
                                            <Label Text="Today"
                                                   FontSize="12"
                                                   VerticalOptions="Center"
                                                   TextColor="{AppThemeBinding Light=#0F766E, Dark=#7DE6D7}"
                                                   IsVisible="{Binding IsToday}" />
                                        </HorizontalStackLayout>
                                        <Label Text="{Binding MuscleGroupSummary}"
                                               FontSize="13"
                                               LineBreakMode="WordWrap"
                                               MaxLines="3"
                                               TextColor="{AppThemeBinding Light=#0F766E, Dark=#7DE6D7}" />
                                        <Label Text="{Binding WorkoutCountLabel}"
                                               FontSize="12"
                                               TextColor="{AppThemeBinding Light=#607084, Dark=#98A8BC}" />
                                    </VerticalStackLayout>

                                    <Button Grid.Column="2"
                                            Text="Edit"
                                            Padding="14,8"
                                            VerticalOptions="Center"
                                            BackgroundColor="{AppThemeBinding Light=#E7F6F4, Dark=#143936}"
                                            TextColor="{AppThemeBinding Light=#0F766E, Dark=#7DE6D7}"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:WeeklyScheduleViewModel}}, Path=EditDayCommand}"
                                            CommandParameter="{Binding Day}" />
                                </Grid>

                                <Border StrokeThickness="0"
                                        BackgroundColor="{AppThemeBinding Light=#F5F7FA, Dark=#1B2431}"
                                        StrokeShape="RoundRectangle 16"
                                        Padding="14"
                                        IsVisible="{Binding ShowRestDayMessage}">
                                    <Label Text="{Binding RestDayMessage}"
                                           FontSize="14"
                                           FontAttributes="Italic"
                                           HorizontalOptions="Center"
                                           TextColor="{AppThemeBinding Light=#6A7686, Dark=#9BABBE}" />
                                </Border>

                                <VerticalStackLayout Spacing="10"
                                                     IsVisible="{Binding IsExpanded}"
                                                     BindableLayout.ItemsSource="{Binding VisibleWorkouts}">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate>
                                            <Border Stroke="{AppThemeBinding Light=#E0E7EF, Dark=#334050}"
                                                    BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#1A2230}"
                                                    StrokeShape="RoundRectangle 18"
                                                    Padding="12">
                                                <VerticalStackLayout Spacing="6">
                                                    <Label Text="{Binding Name}"
                                                           FontSize="16"
                                                           FontAttributes="Bold" />

                                                    <Grid ColumnDefinitions="Auto,Auto,Auto"
                                                          ColumnSpacing="16"
                                                          HorizontalOptions="Start"
                                                          IsVisible="{Binding Type, Converter={StaticResource IsWeightLiftingConverter}}">
                                                        <VerticalStackLayout Grid.Column="0"
                                                                             Spacing="1">
                                                            <Label Text="{Binding Sets, StringFormat='Sets: {0}'}"
                                                                   FontSize="13"
                                                                   TextColor="{AppThemeBinding Light=#6A7686, Dark=#9BABBE}" />
                                                            <Label Text="{Binding RepDisplay, StringFormat='Reps: {0}'}"
                                                                   FontSize="13"
                                                                   TextColor="{AppThemeBinding Light=#6A7686, Dark=#9BABBE}" />
                                                        </VerticalStackLayout>
                                                        <VerticalStackLayout Grid.Column="1"
                                                                             Spacing="1">
                                                            <Label Text="{Binding Weight, StringFormat='Weight: {0}'}"
                                                                   FontSize="13"
                                                                   TextColor="{AppThemeBinding Light=#6A7686, Dark=#9BABBE}" />
                                                            <Label Text="{Binding MuscleGroup, StringFormat='Focus: {0}'}"
                                                                   FontSize="13"
                                                                   TextColor="{AppThemeBinding Light=#6A7686, Dark=#9BABBE}" />
                                                        </VerticalStackLayout>
                                                        <VerticalStackLayout Grid.Column="2"
                                                                             Spacing="1">
                                                            <Label Text="{Binding TargetRpeDisplay, StringFormat='RPE: {0}'}"
                                                                   FontSize="13"
                                                                   TextColor="{AppThemeBinding Light=#6A7686, Dark=#9BABBE}"
                                                                   IsVisible="{Binding HasTargetRpe}" />
                                                            <Label Text="{Binding TargetRestRange, StringFormat='Rest: {0}'}"
                                                                   FontSize="13"
                                                                   TextColor="{AppThemeBinding Light=#6A7686, Dark=#9BABBE}"
                                                                   IsVisible="{Binding HasTargetRestRange}" />
                                                        </VerticalStackLayout>
                                                    </Grid>

                                                    <Label Text="{Binding DurationMinutes, StringFormat='Time goal: {0} min'}"
                                                           FontSize="13"
                                                           IsVisible="{Binding HasDuration}" />
                                                    <Label Text="{Binding DistanceMiles, StringFormat='Distance goal: {0:F1} mi'}"
                                                           FontSize="13"
                                                           IsVisible="{Binding HasDistance}" />
                                                    <Label Text="{Binding Steps, StringFormat='Tracked steps: {0}'}"
                                                            FontSize="13"
                                                            IsVisible="{Binding HasSteps}" />

                                                </VerticalStackLayout>
                                            </Border>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
