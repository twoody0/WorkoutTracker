<?xml version="1.0" encoding="utf-8" ?>
<ContentPage 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:WorkoutTracker.ViewModels"
    xmlns:models="clr-namespace:WorkoutTracker.Models"
    x:Class="WorkoutTracker.Views.ViewWorkoutPage"
    Title="View Workouts">

    <CollectionView ItemsSource="{Binding Workouts}">
        <CollectionView.ItemTemplate>
            <DataTemplate>
                <Border Padding="10" Margin="5" Stroke="LightGray" StrokeShape="RoundRectangle 5">
                    <StackLayout>
                        <Label Text="{Binding Name}" FontAttributes="Bold" />
                        <Label Text="{Binding Type}" />

                        <!-- WeightLifting Section -->
                        <StackLayout x:Name="WeightLiftingSection" IsVisible="False">
                            <StackLayout.Triggers>
                                <DataTrigger TargetType="StackLayout"
                                             Binding="{Binding Type}"
                                             Value="{x:Static models:WorkoutType.WeightLifting}">
                                    <Setter Property="IsVisible" Value="True"/>
                                </DataTrigger>
                            </StackLayout.Triggers>
                            <Label Text="{Binding Weight, StringFormat='Weight: {0}'}"
                                   IsVisible="{Binding HasWeightTarget}" />
                            <Label Text="{Binding RepDisplay, StringFormat='Reps: {0}'}"
                                   IsVisible="{Binding HasRepTarget}" />
                            <Label Text="{Binding DurationValueDisplay, StringFormat='Time: {0}'}"
                                   IsVisible="{Binding HasTimedTarget}" />
                            <Label Text="{Binding Sets, StringFormat='Sets: {0}'}" />
                            <Label Text="{Binding EstimatedOneRepMax, StringFormat='Estimated 1RM: {0:N0}'}"
                                   IsVisible="{Binding HasEstimatedOneRepMax}" />
                        </StackLayout>

                        <!-- Cardio Section -->
                        <StackLayout x:Name="CardioSection" IsVisible="False">
                            <StackLayout.Triggers>
                                <DataTrigger TargetType="StackLayout"
                                             Binding="{Binding Type}"
                                             Value="{x:Static models:WorkoutType.Cardio}">
                                    <Setter Property="IsVisible" Value="True"/>
                                </DataTrigger>
                            </StackLayout.Triggers>
                            <Label Text="{Binding DurationValueDisplay, StringFormat='Time: {0}'}"
                                   IsVisible="{Binding HasDuration}" />
                            <Label Text="{Binding DistanceMiles, StringFormat='Distance: {0:0.##} mi'}"
                                    IsVisible="{Binding HasDistance}" />
                            <Label Text="{Binding Steps, StringFormat='Tracked steps: {0}'}"
                                   IsVisible="{Binding HasSteps}" />
                        </StackLayout>
                        <Button
                            Text="Copy to Add"
                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ViewWorkoutViewModel}}, Path=CopyWorkoutCommand}"
                            CommandParameter="{Binding}" />
                    </StackLayout>
                </Border>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
</ContentPage>
