<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="WorkoutTracker.Views.HomePage"
             Title="Home">

    <ScrollView>
        <VerticalStackLayout Padding="20,18,20,28"
                             Spacing="16">
            <Border StrokeThickness="0"
                    BackgroundColor="{AppThemeBinding Light=#F4F8FB, Dark=#111A24}"
                    StrokeShape="RoundRectangle 28"
                    Padding="22">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{Binding WelcomeMessage}"
                           FontSize="28"
                           FontAttributes="Bold" />
                    <Label Text="Track your training, tune your plan, and keep the next workout obvious."
                           FontSize="14"
                           TextColor="{AppThemeBinding Light=#5E6B7B, Dark=#A4B2C5}" />
                </VerticalStackLayout>
            </Border>

            <Grid ColumnDefinitions="*,*"
                  ColumnSpacing="12">
                <Border Grid.Column="0"
                        Stroke="{AppThemeBinding Light=#D6DEE8, Dark=#2A3442}"
                        BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#141B24}"
                        StrokeShape="RoundRectangle 22"
                        Padding="16">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Profile"
                               FontAttributes="Bold"
                               FontSize="18" />
                        <Label Text="{Binding BodyWeightSummary}"
                               TextColor="{AppThemeBinding Light=#5A6472, Dark=#A4B2C5}" />
                        <Label Text="{Binding BodyWeightReminderText}"
                               TextColor="{AppThemeBinding Light=#B96A10, Dark=#F0BA74}"
                               FontSize="12"
                               IsVisible="{Binding ShowBodyWeightReminder}" />
                        <Button Text="{Binding BodyWeightButtonText}"
                                Clicked="OnEditBodyWeightClicked"
                                BackgroundColor="{AppThemeBinding Light=#0F766E, Dark=#14B8A6}"
                                TextColor="White" />
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Column="1"
                        Stroke="{AppThemeBinding Light=#D6DEE8, Dark=#2A3442}"
                        BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#141B24}"
                        StrokeShape="RoundRectangle 22"
                        Padding="16">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Theme"
                               FontAttributes="Bold"
                               FontSize="18" />
                        <Label Text="{Binding ThemeLabel}" />
                        <Button Text="{Binding ThemeButtonText}"
                                Command="{Binding ToggleThemeCommand}"
                                BackgroundColor="{AppThemeBinding Light=#1F2937, Dark=#334155}"
                                TextColor="White" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <Border IsVisible="{Binding IsUserLoggedIn}"
                    Stroke="{AppThemeBinding Light=#D6DEE8, Dark=#2A3442}"
                    BackgroundColor="{AppThemeBinding Light=#FBFBFC, Dark=#141B24}"
                    StrokeShape="RoundRectangle 24"
                    Padding="18">
                <VerticalStackLayout Spacing="16">
                    <Grid ColumnDefinitions="Auto,Auto"
                          ColumnSpacing="8"
                          HorizontalOptions="Center">
                        <Label Grid.Column="0"
                               Text="Muscle Heat"
                               FontSize="22"
                               FontAttributes="Bold"
                               VerticalOptions="Center" />
                        <ImageButton Grid.Column="1"
                                     Source="info.png"
                                     Command="{Binding ToggleHeatInfoCommand}"
                                     WidthRequest="20"
                                     HeightRequest="20"
                                     MinimumWidthRequest="0"
                                     MinimumHeightRequest="0"
                                     Padding="0"
                                     BackgroundColor="Transparent"
                                     BorderWidth="0"
                                     Aspect="AspectFit"
                                     VerticalOptions="Center" />
                    </Grid>

                    <Label Text="{Binding TodaySummary}"
                           HorizontalTextAlignment="Center"
                           TextColor="{AppThemeBinding Light=#667384, Dark=#A2B0C2}" />

                    <Border IsVisible="{Binding IsHeatInfoVisible}"
                            BackgroundColor="{AppThemeBinding Light=#F1F3F6, Dark=#1B2431}"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 12"
                            Padding="12,10">
                        <Label Text="{Binding HeatInfoText}"
                               HorizontalTextAlignment="Center"
                               TextColor="{AppThemeBinding Light=#5A6472, Dark=#A4B2C5}"
                               FontSize="12" />
                    </Border>

                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="16">
                        <VerticalStackLayout Grid.Column="0"
                                             HorizontalOptions="Center"
                                             Spacing="8">
                            <Label Text="Front"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center" />
                            <Border Stroke="{AppThemeBinding Light=#ECEEF2, Dark=#2B3544}"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 18"
                                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1A2230}"
                                    Padding="4,2">
                                <Grid WidthRequest="190"
                                      HeightRequest="300">
                                    <Image Source="body_front_base.png"
                                           Aspect="AspectFit" />
                                    <Image Source="body_front_shoulders.png"
                                           Aspect="AspectFit"
                                           Opacity="{Binding FrontShouldersOpacity}" />
                                    <Image Source="body_front_chest.png"
                                           Aspect="AspectFit"
                                           Opacity="{Binding FrontChestOpacity}" />
                                    <Image Source="body_front_biceps.png"
                                           Aspect="AspectFit"
                                           Opacity="{Binding FrontBicepsOpacity}" />
                                    <Image Source="body_front_triceps.png"
                                           Aspect="AspectFit"
                                           Opacity="{Binding FrontTricepsOpacity}" />
                                    <Image Source="body_front_abs.png"
                                           Aspect="AspectFit"
                                           Opacity="{Binding FrontAbsOpacity}" />
                                    <Image Source="body_front_quads.png"
                                           Aspect="AspectFit"
                                           Opacity="{Binding FrontQuadsOpacity}" />
                                </Grid>
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1"
                                             HorizontalOptions="Center"
                                             Spacing="8">
                            <Label Text="Back"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center" />
                            <Border Stroke="{AppThemeBinding Light=#ECEEF2, Dark=#2B3544}"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 18"
                                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1A2230}"
                                    Padding="4,2">
                                <Grid WidthRequest="190"
                                      HeightRequest="300">
                                    <Image Source="body_back_base.png"
                                           Aspect="AspectFit" />
                                    <Image Source="body_back_shoulders.png"
                                           Aspect="AspectFit"
                                           Opacity="{Binding BackShouldersOpacity}" />
                                    <Image Source="body_back_triceps.png"
                                           Aspect="AspectFit"
                                           Opacity="{Binding BackTricepsOpacity}" />
                                    <Image Source="body_back_lats.png"
                                           Aspect="AspectFit"
                                           Opacity="{Binding BackLatsOpacity}" />
                                    <Image Source="body_back_lower_back.png"
                                           Aspect="AspectFit"
                                           Opacity="{Binding BackLowerBackOpacity}" />
                                    <Image Source="body_back_glutes.png"
                                           Aspect="AspectFit"
                                           Opacity="{Binding BackGlutesOpacity}" />
                                    <Image Source="body_back_hamstrings.png"
                                           Aspect="AspectFit"
                                           Opacity="{Binding BackHamstringsOpacity}" />
                                    <Image Source="body_back_calves.png"
                                           Aspect="AspectFit"
                                           Opacity="{Binding BackCalvesOpacity}" />
                                </Grid>
                            </Border>
                        </VerticalStackLayout>
                    </Grid>

                    <VerticalStackLayout Spacing="10">
                        <Label Text="Heat Guide"
                               FontAttributes="Bold"
                               HorizontalOptions="Center" />
                        <HorizontalStackLayout HorizontalOptions="Center"
                                               Spacing="16">
                            <HorizontalStackLayout Spacing="8">
                                <Border WidthRequest="18"
                                        HeightRequest="18"
                                        BackgroundColor="#F7D6D6"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 9" />
                                <Label Text="Light"
                                       VerticalOptions="Center"
                                       FontSize="12" />
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Spacing="8">
                                <Border WidthRequest="18"
                                        HeightRequest="18"
                                        BackgroundColor="#E97878"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 9" />
                                <Label Text="Moderate"
                                       VerticalOptions="Center"
                                       FontSize="12" />
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Spacing="8">
                                <Border WidthRequest="18"
                                        HeightRequest="18"
                                        BackgroundColor="#FF0000"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 9" />
                                <Label Text="High effort"
                                       VerticalOptions="Center"
                                       FontSize="12" />
                            </HorizontalStackLayout>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <VerticalStackLayout IsVisible="{Binding ShowAuthenticationActions}"
                                 Spacing="12">
                <Button Text="Login"
                        Command="{Binding NavigateToLoginCommand}" />
                <Button Text="Sign Up"
                        Command="{Binding NavigateToSignupCommand}"
                        BackgroundColor="{AppThemeBinding Light=#E7F6F4, Dark=#143936}"
                        TextColor="{AppThemeBinding Light=#0F766E, Dark=#7DE6D7}" />
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="12">
                <Button Text="Sign Out"
                        Command="{Binding SignOutCommand}"
                        IsVisible="{Binding CanSignOut}"
                        BackgroundColor="{AppThemeBinding Light=#FDECEC, Dark=#442327}"
                        TextColor="{AppThemeBinding Light=#C24141, Dark=#F4A4A4}" />
                <Button Text="Dashboard"
                        Command="{Binding NavigateToDashboardCommand}"
                        IsVisible="{Binding IsUserLoggedIn}" />
                <Button Text="Leaderboard"
                        Command="{Binding NavigateToLeaderboardCommand}"
                        IsVisible="{Binding HasLeaderboard}"
                        BackgroundColor="{AppThemeBinding Light=#1F2937, Dark=#334155}"
                        TextColor="White" />
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
