<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="WorkoutTracker.Views.HomePage"
             Title="Heat Map">

    <ScrollView>
        <VerticalStackLayout Padding="20,18,20,28"
                             Spacing="16">
            <Border Stroke="{AppThemeBinding Light=#D6DEE8, Dark=#2A3442}"
                    BackgroundColor="{AppThemeBinding Light=#FBFBFC, Dark=#141B24}"
                    StrokeShape="RoundRectangle 24"
                    Padding="18">
                <VerticalStackLayout Spacing="16">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Muscle Heat"
                               FontSize="24"
                               FontAttributes="Bold"
                               HorizontalTextAlignment="Center" />
                        <Label Text="See which areas have gotten the most recent lifting work."
                               FontSize="13"
                               HorizontalTextAlignment="Center"
                               TextColor="{AppThemeBinding Light=#667384, Dark=#A2B0C2}" />
                    </VerticalStackLayout>

                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="8">
                        <Label Grid.Column="0"
                               Text="{Binding TodaySummary}"
                               VerticalOptions="Center"
                               TextColor="{AppThemeBinding Light=#667384, Dark=#A2B0C2}" />
                        <ImageButton Grid.Column="1"
                                      Source="info.png"
                                      Command="{Binding ToggleHeatInfoCommand}"
                                     WidthRequest="20"
                                     HeightRequest="20"
                                     MinimumWidthRequest="0"
                                     MinimumHeightRequest="0"
                                     Padding="0"
                                      BackgroundColor="Transparent"
                                      BorderWidth="0"
                                      Aspect="AspectFit"
                                      VerticalOptions="Center" />
                    </Grid>

                    <Border IsVisible="{Binding IsHeatInfoVisible}"
                            BackgroundColor="{AppThemeBinding Light=#F1F3F6, Dark=#1B2431}"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 12"
                            Padding="12,10">
                        <Label Text="{Binding HeatInfoText}"
                               HorizontalTextAlignment="Center"
                               TextColor="{AppThemeBinding Light=#5A6472, Dark=#A4B2C5}"
                               FontSize="12" />
                    </Border>

                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="16">
                        <VerticalStackLayout Grid.Column="0"
                                             HorizontalOptions="Center"
                                             Spacing="8">
                            <Label Text="Front"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center" />
                            <Border Stroke="{AppThemeBinding Light=#ECEEF2, Dark=#2B3544}"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 18"
                                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1A2230}"
                                    Padding="4,2">
                                <Grid WidthRequest="190"
                                      HeightRequest="300">
                                    <Image Source="body_front_base.webp"
                                           Aspect="AspectFit" />
                                    <Image Source="body_front_shoulders.webp"
                                           Aspect="AspectFit"
                                           Opacity="{Binding FrontShouldersOpacity}" />
                                    <Image Source="body_front_chest.webp"
                                           Aspect="AspectFit"
                                           Opacity="{Binding FrontChestOpacity}" />
                                    <Image Source="body_front_biceps.webp"
                                           Aspect="AspectFit"
                                           Opacity="{Binding FrontBicepsOpacity}" />
                                    <Image Source="body_front_forearms.webp"
                                           Aspect="AspectFit"
                                           Opacity="{Binding FrontForearmsOpacity}" />
                                    <Image Source="body_front_triceps.webp"
                                           Aspect="AspectFit"
                                           Opacity="{Binding FrontTricepsOpacity}" />
                                    <Image Source="body_front_abs.webp"
                                           Aspect="AspectFit"
                                           Opacity="{Binding FrontAbsOpacity}" />
                                    <Image Source="body_front_quads.webp"
                                           Aspect="AspectFit"
                                           Opacity="{Binding FrontQuadsOpacity}" />
                                </Grid>
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1"
                                             HorizontalOptions="Center"
                                             Spacing="8">
                            <Label Text="Back"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center" />
                            <Border Stroke="{AppThemeBinding Light=#ECEEF2, Dark=#2B3544}"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 18"
                                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1A2230}"
                                    Padding="4,2">
                                <Grid WidthRequest="190"
                                      HeightRequest="300">
                                    <Image Source="body_back_base.webp"
                                           Aspect="AspectFit" />
                                    <Image Source="body_back_shoulders.webp"
                                           Aspect="AspectFit"
                                           Opacity="{Binding BackShouldersOpacity}" />
                                    <Image Source="body_back_traps.webp"
                                           Aspect="AspectFit"
                                           Opacity="{Binding BackTrapsOpacity}" />
                                    <Image Source="body_back_rhomboids.webp"
                                           Aspect="AspectFit"
                                           Opacity="{Binding BackRhomboidsOpacity}" />
                                    <Image Source="body_back_triceps.webp"
                                           Aspect="AspectFit"
                                           Opacity="{Binding BackTricepsOpacity}" />
                                    <Image Source="body_back_lats.webp"
                                           Aspect="AspectFit"
                                           Opacity="{Binding BackLatsOpacity}" />
                                    <Image Source="body_back_lower_back.webp"
                                           Aspect="AspectFit"
                                           Opacity="{Binding BackLowerBackOpacity}" />
                                    <Image Source="body_back_glutes.webp"
                                           Aspect="AspectFit"
                                           Opacity="{Binding BackGlutesOpacity}" />
                                    <Image Source="body_back_hamstrings.webp"
                                           Aspect="AspectFit"
                                           Opacity="{Binding BackHamstringsOpacity}" />
                                    <Image Source="body_back_calves.webp"
                                           Aspect="AspectFit"
                                           Opacity="{Binding BackCalvesOpacity}" />
                                </Grid>
                            </Border>
                        </VerticalStackLayout>
                    </Grid>

                    <VerticalStackLayout Spacing="10">
                        <Label Text="Heat Guide"
                               FontAttributes="Bold"
                               HorizontalOptions="Center" />
                        <HorizontalStackLayout HorizontalOptions="Center"
                                               Spacing="16">
                            <HorizontalStackLayout Spacing="8">
                                <Border WidthRequest="18"
                                        HeightRequest="18"
                                        BackgroundColor="#F7D6D6"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 9" />
                                <Label Text="Light"
                                       VerticalOptions="Center"
                                       FontSize="12" />
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Spacing="8">
                                <Border WidthRequest="18"
                                        HeightRequest="18"
                                        BackgroundColor="#D98686"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 9" />
                                <Label Text="Moderate"
                                       VerticalOptions="Center"
                                       FontSize="12" />
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Spacing="8">
                                <Border WidthRequest="18"
                                        HeightRequest="18"
                                        BackgroundColor="#C94A4A"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 9" />
                                <Label Text="High effort"
                                       VerticalOptions="Center"
                                       FontSize="12" />
                            </HorizontalStackLayout>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
