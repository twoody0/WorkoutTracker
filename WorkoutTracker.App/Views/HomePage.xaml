<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
       xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       x:Class="WorkoutTracker.Views.HomePage"
       Title="Home">

       <ScrollView>
              <StackLayout Padding="20"
                           VerticalOptions="Center"
                           Spacing="15">
                      <Label Text="{Binding WelcomeMessage}"
                             FontSize="20"
                             HorizontalOptions="Center"/>

                      <Border Stroke="#E4E6EB"
                              StrokeThickness="1"
                              StrokeShape="RoundRectangle 16"
                              BackgroundColor="#FFFFFF"
                              Padding="14">
                             <VerticalStackLayout Spacing="10">
                                    <Label Text="Profile"
                                           FontAttributes="Bold"
                                           FontSize="18"/>
                                    <Label Text="{Binding BodyWeightSummary}"
                                           TextColor="#5A6472"/>
                                    <Label Text="{Binding BodyWeightReminderText}"
                                           TextColor="#C26A00"
                                           FontSize="12"
                                           IsVisible="{Binding ShowBodyWeightReminder}"/>
                                    <Button Text="{Binding BodyWeightButtonText}"
                                            Clicked="OnEditBodyWeightClicked"/>
                             </VerticalStackLayout>
                      </Border>

                      <Border IsVisible="{Binding IsUserLoggedIn}"
                              Stroke="#E4E6EB"
                             StrokeThickness="1"
                             StrokeShape="RoundRectangle 20"
                             BackgroundColor="#FBFBFC"
                             Padding="18">
                            <VerticalStackLayout Spacing="16">
                                   <Grid ColumnDefinitions="Auto,Auto"
                                         ColumnSpacing="8"
                                         HorizontalOptions="Center">
                                          <Label Grid.Column="0"
                                                 Text="Muscle Heat"
                                                 FontSize="22"
                                                 FontAttributes="Bold"
                                                 VerticalOptions="Center"/>
                                          <ImageButton Grid.Column="1"
                                                       Source="info.png"
                                                       Command="{Binding ToggleHeatInfoCommand}"
                                                       WidthRequest="20"
                                                       HeightRequest="20"
                                                       MinimumWidthRequest="0"
                                                       MinimumHeightRequest="0"
                                                       Padding="0"
                                                       BackgroundColor="Transparent"
                                                       BorderWidth="0"
                                                       Aspect="AspectFit"
                                                       VerticalOptions="Center"/>
                                   </Grid>

                                   <Label Text="{Binding TodaySummary}"
                                          HorizontalTextAlignment="Center"
                                          TextColor="Gray"/>

                                   <Border IsVisible="{Binding IsHeatInfoVisible}"
                                           BackgroundColor="#F1F3F6"
                                           StrokeThickness="0"
                                           StrokeShape="RoundRectangle 12"
                                           Padding="12,10">
                                          <Label Text="{Binding HeatInfoText}"
                                                 HorizontalTextAlignment="Center"
                                                 TextColor="#5A6472"
                                                 FontSize="12"/>
                                   </Border>

                                   <Grid ColumnDefinitions="*,*"
                                         ColumnSpacing="16">
                                          <VerticalStackLayout Grid.Column="0"
                                                               HorizontalOptions="Center"
                                                               Spacing="8">
                                                 <Label Text="Front"
                                                        FontAttributes="Bold"
                                                        HorizontalOptions="Center"/>
                                                 <Border Stroke="#ECEEF2"
                                                         StrokeThickness="1"
                                                         StrokeShape="RoundRectangle 18"
                                                         BackgroundColor="#FFFFFF"
                                                         Padding="4,2">
                                                        <Grid WidthRequest="190"
                                                              HeightRequest="300">
                                                               <Image Source="body_front_base.png"
                                                                      Aspect="AspectFit"/>
                                                               <Image Source="body_front_shoulders.png"
                                                                      Aspect="AspectFit"
                                                                      Opacity="{Binding FrontShouldersOpacity}"/>
                                                               <Image Source="body_front_chest.png"
                                                                      Aspect="AspectFit"
                                                                      Opacity="{Binding FrontChestOpacity}"/>
                                                               <Image Source="body_front_biceps.png"
                                                                      Aspect="AspectFit"
                                                                      Opacity="{Binding FrontBicepsOpacity}"/>
                                                               <Image Source="body_front_triceps.png"
                                                                      Aspect="AspectFit"
                                                                      Opacity="{Binding FrontTricepsOpacity}"/>
                                                               <Image Source="body_front_abs.png"
                                                                      Aspect="AspectFit"
                                                                      Opacity="{Binding FrontAbsOpacity}"/>
                                                               <Image Source="body_front_quads.png"
                                                                      Aspect="AspectFit"
                                                                      Opacity="{Binding FrontQuadsOpacity}"/>
                                                        </Grid>
                                                 </Border>
                                          </VerticalStackLayout>

                                          <VerticalStackLayout Grid.Column="1"
                                                               HorizontalOptions="Center"
                                                               Spacing="8">
                                                 <Label Text="Back"
                                                        FontAttributes="Bold"
                                                        HorizontalOptions="Center"/>
                                                 <Border Stroke="#ECEEF2"
                                                         StrokeThickness="1"
                                                         StrokeShape="RoundRectangle 18"
                                                         BackgroundColor="#FFFFFF"
                                                         Padding="4,2">
                                                        <Grid WidthRequest="190"
                                                              HeightRequest="300">
                                                               <Image Source="body_back_base.png"
                                                                      Aspect="AspectFit"/>
                                                               <Image Source="body_back_shoulders.png"
                                                                      Aspect="AspectFit"
                                                                      Opacity="{Binding BackShouldersOpacity}"/>
                                                               <Image Source="body_back_triceps.png"
                                                                      Aspect="AspectFit"
                                                                      Opacity="{Binding BackTricepsOpacity}"/>
                                                               <Image Source="body_back_lats.png"
                                                                      Aspect="AspectFit"
                                                                      Opacity="{Binding BackLatsOpacity}"/>
                                                               <Image Source="body_back_lower_back.png"
                                                                      Aspect="AspectFit"
                                                                      Opacity="{Binding BackLowerBackOpacity}"/>
                                                               <Image Source="body_back_glutes.png"
                                                                      Aspect="AspectFit"
                                                                      Opacity="{Binding BackGlutesOpacity}"/>
                                                               <Image Source="body_back_hamstrings.png"
                                                                      Aspect="AspectFit"
                                                                      Opacity="{Binding BackHamstringsOpacity}"/>
                                                               <Image Source="body_back_calves.png"
                                                                      Aspect="AspectFit"
                                                                      Opacity="{Binding BackCalvesOpacity}"/>
                                                        </Grid>
                                                 </Border>
                                          </VerticalStackLayout>
                                   </Grid>

                                   <VerticalStackLayout Spacing="10">
                                          <Label Text="Heat Guide"
                                                 FontAttributes="Bold"
                                                 HorizontalOptions="Center"/>
                                          <HorizontalStackLayout HorizontalOptions="Center"
                                                                 Spacing="16">
                                                 <HorizontalStackLayout Spacing="8">
                                                        <Border WidthRequest="18"
                                                                HeightRequest="18"
                                                                BackgroundColor="#F7D6D6"
                                                                StrokeThickness="0"
                                                                StrokeShape="RoundRectangle 9"/>
                                                        <Label Text="Light"
                                                               VerticalOptions="Center"
                                                               FontSize="12"/>
                                                 </HorizontalStackLayout>
                                                 <HorizontalStackLayout Spacing="8">
                                                        <Border WidthRequest="18"
                                                                HeightRequest="18"
                                                                BackgroundColor="#E97878"
                                                                StrokeThickness="0"
                                                                StrokeShape="RoundRectangle 9"/>
                                                        <Label Text="Moderate"
                                                               VerticalOptions="Center"
                                                               FontSize="12"/>
                                                 </HorizontalStackLayout>
                                                 <HorizontalStackLayout Spacing="8">
                                                        <Border WidthRequest="18"
                                                                HeightRequest="18"
                                                                BackgroundColor="#FF0000"
                                                                StrokeThickness="0"
                                                                StrokeShape="RoundRectangle 9"/>
                                                        <Label Text="High effort"
                                                               VerticalOptions="Center"
                                                               FontSize="12"/>
                                                 </HorizontalStackLayout>
                                          </HorizontalStackLayout>
                                   </VerticalStackLayout>
                            </VerticalStackLayout>
                     </Border>

                      <StackLayout IsVisible="{Binding ShowAuthenticationActions}"
                                   Spacing="20">
                             <Button Text="Login"
                                     Command="{Binding NavigateToLoginCommand}"/>
                             <Button Text="Sign Up"
                                     Command="{Binding NavigateToSignupCommand}"/>
                     </StackLayout>

                      <Button Text="Sign Out"
                              Command="{Binding SignOutCommand}"
                              IsVisible="{Binding CanSignOut}"/>
                     <Button Text="Dashboard"
                             Command="{Binding NavigateToDashboardCommand}"
                             IsVisible="{Binding IsUserLoggedIn}"/>
                      <Button Text="Leaderboard"
                              Command="{Binding NavigateToLeaderboardCommand}"
                              IsVisible="{Binding HasLeaderboard}"/>
               </StackLayout>
        </ScrollView>
 </ContentPage>
